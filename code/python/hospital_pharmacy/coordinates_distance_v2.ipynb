   "source": [
    "# county_v3_distance: pharmacy distance to nearest hospitals, aggregated to county-year.\n",
    "# Run after the county-level pharmacy aggregation cell and before the panel concat cell.\n",
    "# This keeps the original nearest-any-hospital measures and adds nearest-public/private-hospital measures.\n",
    "\n",
    "import os\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from sklearn.neighbors import BallTree\n",
    "\n",
    "output_dir = \"D:/Hospital_Pharmacy program/data/processed/hospital_pharmacy/county_pharmacy_panel\"\n",
    "distance_csv = output_dir + \"/county_pharmacy_nearest_hospital_distance_all_years.csv\"\n",
    "distance_dta = output_dir + \"/county_pharmacy_nearest_hospital_distance_all_years.dta\"\n",
    "\n",
    "EARTH_RADIUS_KM = 6371.0088\n",
    "DISTANCE_CUTOFF_KM = 2.0\n",
    "PUBLIC_WORD = \"\\u516c\\u7acb\"\n",
    "PRIVATE_WORD = \"\\u6c11\\u8425\"\n",
    "HOSPITAL_TYPE_COL = \"\\u4f01\\u4e1a\\u7ecf\\u8425\\u65b9\\u5f0f\"\n",
    "\n",
    "if \"safe_read_csv\" not in globals():\n",
    "    import chardet\n",
    "\n",
    "    def get_file_encoding(file_path: str) -> str:\n",
    "        with open(file_path, \"rb\") as f:\n",
    "            raw = f.read(10000)\n",
    "        return chardet.detect(raw)[\"encoding\"] or \"utf-8\"\n",
    "\n",
    "    def safe_read_csv(file_path: str, **kwargs):\n",
    "        for enc in [get_file_encoding(file_path), \"utf-8-sig\", \"utf-8\", \"gb18030\", \"gbk\", \"gb2312\", \"latin1\"]:\n",
    "            try:\n",
    "                return pd.read_csv(file_path, encoding=enc, **kwargs)\n",
    "            except Exception:\n",
    "                continue\n",
    "        print(\"  [ERR] cannot read: {}\".format(file_path))\n",
    "        return None\n",
    "\n",
    "\n",
    "def _valid_wgs84(df, lon_col, lat_col):\n",
    "    df[lon_col] = pd.to_numeric(df[lon_col], errors=\"coerce\")\n",
    "    df[lat_col] = pd.to_numeric(df[lat_col], errors=\"coerce\")\n",
    "    return df[\n",
    "        df[lon_col].between(-180, 180) &\n",
    "        df[lat_col].between(-90, 90)\n",
    "    ].copy()\n",
    "\n",
    "\n",
    "def _nearest_distance_km(pharmacy_df, hospital_df):\n",
    "    \"\"\"Return nearest-hospital distance in km for every pharmacy row.\"\"\"\n",
    "    if hospital_df.empty:\n",
    "        return np.full(len(pharmacy_df), np.nan)\n",
    "    hospital_rad = np.radians(hospital_df[[\"wgs_lat_true\", \"wgs_lon_true\"]].to_numpy())\n",
    "    pharmacy_rad = np.radians(pharmacy_df[[\"lat_wgs\", \"lon_wgs\"]].to_numpy())\n",
    "    tree = BallTree(hospital_rad, metric=\"haversine\")\n",
    "    dist_rad, _ = tree.query(pharmacy_rad, k=1)\n",
    "    return dist_rad[:, 0] * EARTH_RADIUS_KM\n",
    "\n",
    "\n",
    "def _hospital_type_series(hospital_df):\n",
    "    \"\"\"Find the public/private hospital type column without relying on terminal encoding.\"\"\"\n",
    "    if HOSPITAL_TYPE_COL in hospital_df.columns:\n",
    "        return hospital_df[HOSPITAL_TYPE_COL].astype(str).str.strip()\n",
    "\n",
    "    for col in hospital_df.columns:\n",
    "        s = hospital_df[col].astype(str).str.strip()\n",
    "        if s.str.contains(PUBLIC_WORD, na=False).any() or s.str.contains(PRIVATE_WORD, na=False).any():\n",
    "            print(\"  [INFO] using inferred hospital type column: {}\".format(col))\n",
    "            return s\n",
    "\n",
    "    print(\"  [WARN] hospital type column not found; public/private distance variables will be missing\")\n",
    "    return pd.Series([\"\"] * len(hospital_df), index=hospital_df.index)\n",
    "\n",
    "\n",
    "def compute_county_nearest_hospital_distance(year: int):\n",
    "    pharmacy_path = (\n",
    "        \"D:/Hospital_Pharmacy program/data/processed/pharmacy/real_pharmacy_data/\"\n",
    "        \"real_pharmacy_dzdp_pharmacies_{}.csv\".format(year)\n",
    "    )\n",
    "    hospital_path = (\n",
    "        \"D:/Hospital_Pharmacy program/hospital/register data/register 2022/\"\n",
    "        \"final data/hospital_registerd/hospital_register_final_{}.csv\".format(year)\n",
    "    )\n",
    "\n",
    "    pharmacy_df = safe_read_csv(pharmacy_path, low_memory=False)\n",
    "    hospital_df = safe_read_csv(hospital_path, low_memory=False)\n",
    "    if pharmacy_df is None or hospital_df is None:\n",
    "        return None\n",
    "\n",
    "    pharmacy_df[\"PAC\"] = pd.to_numeric(pharmacy_df[\"PAC\"], errors=\"coerce\")\n",
    "    pharmacy_df = pharmacy_df[pharmacy_df[\"PAC\"].notna()].copy()\n",
    "    pharmacy_df[\"PAC\"] = pharmacy_df[\"PAC\"].astype(int)\n",
    "    pharmacy_df = _valid_wgs84(pharmacy_df, \"lon_wgs\", \"lat_wgs\")\n",
    "\n",
    "    hospital_df[\"county_id\"] = pd.to_numeric(hospital_df[\"county_id\"], errors=\"coerce\")\n",
    "    hospital_df = hospital_df[hospital_df[\"county_id\"].notna()].copy()\n",
    "    hospital_df[\"county_id\"] = hospital_df[\"county_id\"].astype(int)\n",
    "    hospital_df = _valid_wgs84(hospital_df, \"wgs_lon_true\", \"wgs_lat_true\")\n",
    "\n",
    "    if pharmacy_df.empty or hospital_df.empty:\n",
    "        print(\"  [WARN] {} has no valid pharmacy or hospital coordinates\".format(year))\n",
    "        return None\n",
    "\n",
    "    hospital_type = _hospital_type_series(hospital_df)\n",
    "    public_hospital_df = hospital_df[hospital_type.str.contains(PUBLIC_WORD, na=False)].copy()\n",
    "    private_hospital_df = hospital_df[hospital_type.str.contains(PRIVATE_WORD, na=False)].copy()\n",
    "\n",
    "    # 1. Original measure: nearest hospital of any ownership type.\n",
    "    pharmacy_df[\"nearest_hospital_km\"] = _nearest_distance_km(pharmacy_df, hospital_df)\n",
    "    pharmacy_df[\"pharmacy_within_2km_flag\"] = (pharmacy_df[\"nearest_hospital_km\"] <= DISTANCE_CUTOFF_KM).astype(int)\n",
    "    pharmacy_df[\"pharmacy_over_2km_flag\"] = (pharmacy_df[\"nearest_hospital_km\"] > DISTANCE_CUTOFF_KM).astype(int)\n",
    "\n",
    "    # 2. New measure: nearest public hospital.\n",
    "    pharmacy_df[\"nearest_public_hospital_km\"] = _nearest_distance_km(pharmacy_df, public_hospital_df)\n",
    "    pharmacy_df[\"pharmacy_within_2km_public_flag\"] = (\n",
    "        pharmacy_df[\"nearest_public_hospital_km\"] <= DISTANCE_CUTOFF_KM\n",
    "    ).astype(int)\n",
    "\n",
    "    # 3. New measure: nearest private hospital.\n",
    "    pharmacy_df[\"nearest_private_hospital_km\"] = _nearest_distance_km(pharmacy_df, private_hospital_df)\n",
    "    pharmacy_df[\"pharmacy_within_2km_private_flag\"] = (\n",
    "        pharmacy_df[\"nearest_private_hospital_km\"] <= DISTANCE_CUTOFF_KM\n",
    "    ).astype(int)\n",
    "\n",
    "    county_distance = (\n",
    "        pharmacy_df\n",
    "        .groupby(\"PAC\")\n",
    "        .agg(\n",
    "            pharmacy_count_for_distance=(\"PAC\", \"count\"),\n",
    "            mean_nearest_hospital_km=(\"nearest_hospital_km\", \"mean\"),\n",
    "            median_nearest_hospital_km=(\"nearest_hospital_km\", \"median\"),\n",
    "            pharmacy_within_2km=(\"pharmacy_within_2km_flag\", \"sum\"),\n",
    "            pharmacy_over_2km=(\"pharmacy_over_2km_flag\", \"sum\"),\n",
    "            mean_nearest_public_hosp_km=(\"nearest_public_hospital_km\", \"mean\"),\n",
    "            median_nearest_public_hosp_km=(\"nearest_public_hospital_km\", \"median\"),\n",
    "            pharmacy_2km_public_hosp=(\"pharmacy_within_2km_public_flag\", \"sum\"),\n",
    "            mean_nearest_private_hosp_km=(\"nearest_private_hospital_km\", \"mean\"),\n",
    "            median_nearest_private_hosp_km=(\"nearest_private_hospital_km\", \"median\"),\n",
    "            pharmacy_2km_private_hosp=(\"pharmacy_within_2km_private_flag\", \"sum\"),\n",
    "        )\n",
    "        .reset_index()\n",
    "        .rename(columns={\"PAC\": \"county_id\"})\n",
    "    )\n",
    "    county_distance.insert(0, \"year\", year)\n",
    "\n",
    "    count_cols = [\n",
    "        \"pharmacy_count_for_distance\", \"pharmacy_within_2km\", \"pharmacy_over_2km\",\n",
    "        \"pharmacy_2km_public_hosp\", \"pharmacy_2km_private_hosp\",\n",
    "    ]\n",
    "    for c in count_cols:\n",
    "        county_distance[c] = county_distance[c].fillna(0).astype(int)\n",
    "\n",
    "    denom = county_distance[\"pharmacy_count_for_distance\"].replace(0, pd.NA)\n",
    "    county_distance[\"share_pharmacy_within_2km\"] = county_distance[\"pharmacy_within_2km\"] / denom\n",
    "    county_distance[\"share_2km_public_hosp\"] = county_distance[\"pharmacy_2km_public_hosp\"] / denom\n",
    "    county_distance[\"share_2km_private_hosp\"] = county_distance[\"pharmacy_2km_private_hosp\"] / denom\n",
    "\n",
    "    print(\"  {}: pharmacies {}, hospitals {}, public {}, private {}, counties {}\".format(\n",
    "        year, len(pharmacy_df), len(hospital_df), len(public_hospital_df),\n",
    "        len(private_hospital_df), len(county_distance)\n",
    "    ))\n",
    "    return county_distance\n",
    "\n",
    "\n",
    "def merge_distance_into_county_outputs(distance_df: pd.DataFrame):\n",
    "    distance_cols = [\n",
    "        \"year\", \"county_id\",\n",
    "        \"pharmacy_count_for_distance\",\n",
    "        \"mean_nearest_hospital_km\", \"median_nearest_hospital_km\",\n",
    "        \"pharmacy_within_2km\", \"pharmacy_over_2km\", \"share_pharmacy_within_2km\",\n",
    "        \"mean_nearest_public_hosp_km\", \"median_nearest_public_hosp_km\",\n",
    "        \"pharmacy_2km_public_hosp\", \"share_2km_public_hosp\",\n",
    "        \"mean_nearest_private_hosp_km\", \"median_nearest_private_hosp_km\",\n",
    "        \"pharmacy_2km_private_hosp\", \"share_2km_private_hosp\",\n",
    "    ]\n",
    "    distance_df = distance_df[distance_cols].copy()\n",
    "\n",
    "    if \"all_results\" in globals() and all_results:\n",
    "        updated = []\n",
    "        for df in all_results:\n",
    "            y = int(df[\"year\"].iloc[0])\n",
    "            dist_y = distance_df[distance_df[\"year\"] == y].drop(columns=[\"year\"])\n",
    "            legacy_distance_cols = [\"share_pharmacy_2km_public_hosp\", \"share_pharmacy_2km_private_hosp\"]\n",
    "            drop_cols = [c for c in dist_y.columns if c in df.columns and c != \"county_id\"]\n",
    "            drop_cols += [c for c in legacy_distance_cols if c in df.columns]\n",
    "            df2 = df.drop(columns=drop_cols, errors=\"ignore\")\n",
    "            df2 = df2.merge(dist_y, on=\"county_id\", how=\"left\")\n",
    "            for c in [\n",
    "                \"pharmacy_count_for_distance\", \"pharmacy_within_2km\", \"pharmacy_over_2km\",\n",
    "                \"pharmacy_2km_public_hosp\", \"pharmacy_2km_private_hosp\",\n",
    "            ]:\n",
    "                if c in df2.columns:\n",
    "                    df2[c] = df2[c].fillna(0).astype(int)\n",
    "            updated.append(df2)\n",
    "        globals()[\"all_results\"] = updated\n",
    "\n",
    "    for year, dist_y in distance_df.groupby(\"year\"):\n",
    "        county_file = output_dir + \"/county_pharmacy_{}.csv\".format(int(year))\n",
    "        if not os.path.exists(county_file):\n",
    "            print(\"  [WARN] county file missing, skip merge: {}\".format(county_file))\n",
    "            continue\n",
    "        county_df = safe_read_csv(county_file, low_memory=False)\n",
    "        if county_df is None:\n",
    "            continue\n",
    "        county_df[\"county_id\"] = pd.to_numeric(county_df[\"county_id\"], errors=\"coerce\").astype(\"Int64\")\n",
    "        dist_y = dist_y.drop(columns=[\"year\"])\n",
    "        legacy_distance_cols = [\"share_pharmacy_2km_public_hosp\", \"share_pharmacy_2km_private_hosp\"]\n",
    "        drop_cols = [c for c in dist_y.columns if c in county_df.columns and c != \"county_id\"]\n",
    "        drop_cols += [c for c in legacy_distance_cols if c in county_df.columns]\n",
    "        county_df = county_df.drop(columns=drop_cols, errors=\"ignore\")\n",
    "        county_df = county_df.merge(dist_y, on=\"county_id\", how=\"left\")\n",
    "        for c in [\n",
    "            \"pharmacy_count_for_distance\", \"pharmacy_within_2km\", \"pharmacy_over_2km\",\n",
    "            \"pharmacy_2km_public_hosp\", \"pharmacy_2km_private_hosp\",\n",
    "        ]:\n",
    "            if c in county_df.columns:\n",
    "                county_df[c] = county_df[c].fillna(0).astype(int)\n",
    "        county_df.to_csv(county_file, index=False, encoding=\"utf-8-sig\")\n",
    "\n",
    "\n",
    "distance_results = []\n",
    "for year in range(2012, 2023):\n",
    "    df_dist = compute_county_nearest_hospital_distance(year)\n",
    "    if df_dist is not None:\n",
    "        distance_results.append(df_dist)\n",
    "\n",
    "if distance_results:\n",
    "    distance_panel = pd.concat(distance_results, ignore_index=True)\n",
    "    distance_panel.sort_values([\"county_id\", \"year\"], inplace=True)\n",
    "    distance_panel.to_csv(distance_csv, index=False, encoding=\"utf-8-sig\")\n",
    "    print(\"\\nDistance CSV saved: {}\".format(distance_csv))\n",
    "\n",
    "    try:\n",
    "        distance_panel.to_stata(distance_dta, write_index=False, version=118)\n",
    "        print(\"Distance DTA saved: {}\".format(distance_dta))\n",
    "    except Exception as e:\n",
    "        print(\"Distance DTA failed (use CSV instead): {}\".format(e))\n",
    "\n",
    "    merge_distance_into_county_outputs(distance_panel)\n",
    "    print(\"Distance variables merged back into yearly county_pharmacy CSV files and all_results if available.\")\n",
    "else:\n",
    "    print(\"[ERR] no distance results generated\")\n"
   ]
  },
