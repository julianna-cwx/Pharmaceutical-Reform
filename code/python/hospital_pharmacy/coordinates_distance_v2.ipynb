    "import pandas as pd\n",
    "from pathlib import Path\n",
    "import logging\n",
    "from enum import Enum\n",
    "import eviltransform\n",
    "\n",
    "# ------------------------------\n",
    "# 鍧愭爣绯荤粺鏋氫妇\n",
    "# ------------------------------\n",
    "class CoordSystem(Enum):\n",
    "    AMAP = \"amap\"      # 楂樺痉 GCJ-02\n",
    "    BAIDU = \"baidu\"    # 鐧惧害 BD-09\n",
    "\n",
    "# ------------------------------\n",
    "# 閰嶇疆鍖篭n",
    "# ------------------------------\n",
    "class Config:\n",
    "    def __init__(self):\n",
    "        self.base_dir = Path(\n",
    "            r\"D:\\Hospital_Pharmacy program\\data\\processed\\hospital\\coordinates_place_api\"\n",
    "        )\n",
    "        \n",
    "        self.input_file = self.base_dir / \"hospital_place_result.csv\"\n",
    "        self.output_file = self.base_dir / \"hospital_place_baidu_gaode_wgs84.csv\"\n",
    "        \n",
    "        self.columns_map = {\n",
    "            CoordSystem.BAIDU: {\n",
    "                \"lng\": \"鐧惧害缁忓害1\",\n",
    "                \"lat\": \"鐧惧害绾害1\",\n",
    "                \"out_lng\": \"鐧惧害_wgs84缁忓害1\",\n",
    "                \"out_lat\": \"鐧惧害_wgs84绾害1\",\n",
    "            },\n",
    "            CoordSystem.AMAP: {\n",
    "                \"lng\": \"楂樺痉缁忓害\",\n",
    "                \"lat\": \"楂樺痉绾害\",\n",
    "                \"out_lng\": \"楂樺痉_wgs84缁忓害\",\n",
    "                \"out_lat\": \"楂樺痉_wgs84绾害\",\n",
    "            },\n",
    "        }\n",
    "        \n",
    "        logging.basicConfig(\n",
    "            level=logging.INFO,\n",
    "            format=\"%(asctime)s - %(levelname)s - %(message)s\"\n",
    "        )\n",
    "\n",
    "config = Config()\n",
    "\n",
    "# ------------------------------\n",
    "# 鍔犺浇鏂囦欢锛堝寮虹増鏈級\n",
    "# ------------------------------\n",
    "def load_file(path: Path) -> pd.DataFrame:\n",
    "    # 灏濊瘯鏇村叏闈㈢殑缂栫爜鍒楄〃\n",
    "    encodings = [\n",
    "        \"utf-8-sig\", \"utf-8\", \"gbk\", \"gb2312\", \"gb18030\", \n",
    "        \"ansi\", \"iso-8859-1\", \"latin1\", \"cp1252\", \"cp1250\",\n",
    "        \"big5\", \"shift_jis\", \"euc-jp\", \"euc-kr\"\n",
    "    ]\n",
    "    \n",
    "    # 棣栧厛妫€鏌ユ枃浠舵槸鍚﹀瓨鍦╘n",
    "    if not path.exists():\n",
    "        raise FileNotFoundError(f\"鏂囦欢涓嶅瓨鍦細{path}\")\n",
    "    \n",
    "    print(f\"灏濊瘯鍔犺浇鏂囦欢锛歿path}\")\n",
    "    print(f\"鏂囦欢澶у皬锛歿path.stat().st_size} 瀛楄妭\")\n",
    "    \n",
    "    # 灏濊瘯璇诲彇鍓嶅嚑琛屾潵鏌ョ湅鍐呭\n",
    "    try:\n",
    "        with open(path, 'rb') as f:\n",
    "            sample = f.read(500)\n",
    "            print(f\"鏂囦欢鍓?00瀛楄妭锛堝崄鍏繘鍒讹級锛歿sample[:100].hex()}...\")\n",
    "            print(f\"鏂囦欢鍓?00瀛楄妭锛堟枃鏈皾璇曡В鐮佷负utf-8锛夛細{sample[:100].decode('utf-8', errors='ignore')}\")\n",
    "    except Exception as e:\n",
    "        print(f\"鏃犳硶璇诲彇鏂囦欢鏍锋湰锛歿e}\")\n",
    "    \n",
    "    for enc in encodings:\n",
    "        try:\n",
    "            print(f\"灏濊瘯浣跨敤缂栫爜锛歿enc}\")\n",
    "            df = pd.read_csv(path, encoding=enc, low_memory=False)\n",
    "            print(f\"浣跨敤缂栫爜 {enc} 鎴愬姛璇诲彇鏂囦欢\")\n",
    "            print(f\"鏁版嵁褰㈢姸锛歿df.shape}\")\n",
    "            print(f\"鍒楀悕锛歿list(df.columns)}\")\n",
    "            return df\n",
    "        except UnicodeDecodeError as e:\n",
    "            print(f\"缂栫爜 {enc} 澶辫触锛歿str(e)[:100]}\")\n",
    "            continue\n",
    "        except Exception as e:\n",
    "            print(f\"缂栫爜 {enc} 璇诲彇澶辫触锛堥潪瑙ｇ爜閿欒锛夛細{str(e)[:100]}\")\n",
    "            continue\n",
    "    \n",
    "    # 濡傛灉鎵€鏈夌紪鐮侀兘澶辫触锛屽皾璇曚娇鐢?errors='ignore' 鎴?'replace'\n",
    "    print(\"灏濊瘯浣跨敤 errors='ignore' 鏂瑰紡璇诲彇...\")\n",
    "    for enc in [\"utf-8\", \"gbk\", \"ansi\"]:\n",
    "        try:\n",
    "            df = pd.read_csv(path, encoding=enc, encoding_errors='ignore', low_memory=False)\n",
    "            print(f\"浣跨敤缂栫爜 {enc} 鍜?errors='ignore' 鎴愬姛璇诲彇鏂囦欢\")\n",
    "            print(f\"鏁版嵁褰㈢姸锛歿df.shape}\")\n",
    "            return df\n",
    "        except Exception:\n",
    "            continue\n",
    "    \n",
    "    # 鏈€鍚庡皾璇曚娇鐢ㄤ簩杩涘埗妯″紡璇诲彇\n",
    "    print(\"灏濊瘯浣跨敤浜岃繘鍒舵ā寮忚鍙?..\")\n",
    "    try:\n",
    "        df = pd.read_csv(path, encoding='latin1', low_memory=False)\n",
    "        print(\"浣跨敤 latin1 缂栫爜鎴愬姛璇诲彇鏂囦欢\")\n",
    "        return df\n",
    "    except Exception as e:\n",
    "        raise ValueError(f\"鏃犳硶瑙ｆ瀽鏂囦欢缂栫爜锛歿path}锛屽凡灏濊瘯鎵€鏈夌紪鐮佹柟寮忋€傞敊璇細{e}\")\n",
    "\n",
    "# ------------------------------\n",
    "# 鍗曡鍧愭爣杞崲\n",
    "# ------------------------------\n",
    "def convert_coord(row, coord_type: CoordSystem, col_map: dict):\n",
    "    lng = row[col_map[\"lng\"]]\n",
    "    lat = row[col_map[\"lat\"]]\n",
    "    \n",
    "    if pd.isna(lng) or pd.isna(lat):\n",
    "        return None, None\n",
    "    \n",
    "    try:\n",
    "        if coord_type == CoordSystem.AMAP:\n",
    "            wgs_lat, wgs_lng = eviltransform.gcj2wgs(lat, lng)\n",
    "        else:\n",
    "            wgs_lat, wgs_lng = eviltransform.bd2wgs(lat, lng)\n",
    "        \n",
    "        return wgs_lng, wgs_lat\n",
    "    except Exception as e:\n",
    "        print(f\"鍧愭爣杞崲澶辫触: ({lat}, {lng}), 绫诲瀷: {coord_type}, 閿欒: {e}\")\n",
    "        return None, None\n",
    "\n",
    "# ------------------------------\n",
    "# 涓绘祦绋媆n",
    "# ------------------------------\n",
    "def process():\n",
    "    print(\"=\" * 50)\n",
    "    print(\"寮€濮嬭鐩栨洿鏂?WGS84 鍧愭爣\")\n",
    "    print(\"=\" * 50)\n",
    "    \n",
    "    try:\n",
    "        df = load_file(config.input_file)\n",
    "        print(\"鏂囦欢鍔犺浇鎴愬姛\")\n",
    "        \n",
    "        for coord_type, col_map in config.columns_map.items():\n",
    "            print(f\"\\n澶勭悊 {coord_type.value} 鍧愭爣绯荤粺...\")\n",
    "            \n",
    "            required_cols = [\n",
    "                col_map[\"lng\"],\n",
    "                col_map[\"lat\"],\n",
    "                col_map[\"out_lng\"],\n",
    "                col_map[\"out_lat\"],\n",
    "            ]\n",
    "            \n",
    "            # 妫€鏌ュ垪鏄惁瀛樺湪\n",
    "            missing_cols = [col for col in required_cols if col not in df.columns]\n",
    "            if missing_cols:\n",
    "                print(f\"璀﹀憡锛氭枃浠朵腑缂哄皯鍒楋細{missing_cols}\")\n",
    "                print(f\"鐜版湁鍒楋細{list(df.columns)}\")\n",
    "                \n",
    "                # 灏濊瘯瀵绘壘鐩镐技鐨勫垪鍚峔n",
    "                for missing_col in missing_cols:\n",
    "                    similar_cols = [col for col in df.columns if missing_col[:4] in col or missing_col[-4:] in col]\n",
    "                    if similar_cols:\n",
    "                        print(f\"  鍙兘鐩镐技鐨勫垪锛歿similar_cols}\")\n",
    "                \n",
    "                # 濡傛灉缂哄皯杈撳叆鍒楋紝璺宠繃杩欎釜鍧愭爣绯荤粺\n",
    "                if col_map[\"lng\"] not in df.columns or col_map[\"lat\"] not in df.columns:\n",
    "                    print(f\"璺宠繃 {coord_type.value}锛屽洜涓虹己灏戣緭鍏ュ垪\")\n",
    "                    continue\n",
    "            \n",
    "            # 纭繚杈撳嚭鍒楀瓨鍦╘n",
    "            for out_col in [col_map[\"out_lng\"], col_map[\"out_lat\"]]:\n",
    "                if out_col not in df.columns:\n",
    "                    print(f\"娣诲姞缂哄け鐨勮緭鍑哄垪锛歿out_col}\")\n",
    "                    df[out_col] = None\n",
    "            \n",
    "            # 搴旂敤杞崲\n",
    "            df[[col_map[\"out_lng\"], col_map[\"out_lat\"]]] = df.apply(\n",
    "                lambda row: pd.Series(\n",
    "                    convert_coord(row, coord_type, col_map)\n",
    "                ),\n",
    "                axis=1\n",
    "            )\n",
    "            \n",
    "            print(f\"宸叉洿鏂?{coord_type.value} 鈫?WGS84\")\n",
    "            print(f\"鎴愬姛杞崲鏁伴噺锛歿df[col_map['out_lng']].notna().sum()}\")\n",
    "        \n",
    "        # 淇濆瓨鏂囦欢\n",
    "        df.to_csv(config.output_file, index=False, encoding=\"utf-8-sig\")\n",
