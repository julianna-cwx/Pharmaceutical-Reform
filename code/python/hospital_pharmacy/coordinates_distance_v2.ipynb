   "source": [
    "# 鍔犲叆宸ュ晢鏁版嵁鍧愭爣锛岃缃川閲忓垎score + 绛涢€夌己澶卞潗鏍囩敓鎴恗issing鏂囦欢\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import eviltransform  # 鍧愭爣杞崲搴揬n",
    "\n",
    "# 鏂囦欢璺緞\n",
    "file_path = r\"D:\\Hospital_Pharmacy program\\data\\processed\\hospital\\hospital_registered\\hospital_wgs84_final_registered_filled.csv\"\n",
    "\n",
    "# 璇诲彇鏁版嵁\n",
    "df = pd.read_csv(file_path, encoding=\"gb18030\")\n",
    "\n",
    "# 鍒涘缓score鍒梊n",
    "df[\"score\"] = np.nan\n",
    "\n",
    "# 鏉′欢1锛氬凡鏈塛GS84鍧愭爣 鈫?璐ㄩ噺鍒?0\n",
    "cond1 = df[\"wgs_lon_true\"].notna() & df[\"wgs_lat_true\"].notna()\n",
    "df.loc[cond1, \"score\"] = 10\n",
    "\n",
    "# 鏉′欢2锛歐GS84涓虹┖锛屼絾宸ュ晢鍧愭爣瀛樺湪 鈫?鐢ㄥ伐鍟嗗潗鏍囧～琛ワ紝璐ㄩ噺鍒?\n",
    "cond2 = (\n",
    "    df[\"wgs_lon_true\"].isna() &\n",
    "    df[\"wgs_lat_true\"].isna() &\n",
    "    df[\"宸ュ晢缁忓害\"].notna() &\n",
    "    df[\"宸ュ晢绾害\"].notna()\n",
    ")\n",
    "\n",
    "# 鍧愭爣杞崲鍑芥暟锛欸CJ-02 鈫?WGS84\n",
    "def gcj2wgs(lng, lat):\n",
    "    if pd.isna(lng) or pd.isna(lat):\n",
    "        return None, None\n",
    "    wgs_lat, wgs_lng = eviltransform.gcj2wgs(lat, lng)\n",
    "    return wgs_lng, wgs_lat\n",
    "\n",
    "# 宸ュ晢鍧愭爣杞崲涓篧GS84\n",
    "df[[\"宸ュ晢_wgs84缁忓害\", \"宸ュ晢_wgs84绾害\"]] = df.apply(\n",
    "    lambda row: gcj2wgs(row[\"宸ュ晢缁忓害\"], row[\"宸ュ晢绾害\"]), axis=1, result_type=\"expand\"\n",
