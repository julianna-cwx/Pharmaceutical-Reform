    "# 鐢ㄨ浆鎹㈠悗鐨勫伐鍟嗗潗鏍囧～琛ョ┖鐨刉GS鍧愭爣\n",
    "df.loc[cond2, \"wgs_lon_true\"] = df.loc[cond2, \"宸ュ晢_wgs84缁忓害\"]\n",
    "df.loc[cond2, \"wgs_lat_true\"] = df.loc[cond2, \"宸ュ晢_wgs84绾害\"]\n",
