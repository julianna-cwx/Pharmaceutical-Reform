   "source": [
    "# 鍚堝苟澶滈棿鐏厜锛圢TL锛夋暟鎹埌闈㈡澘鏁版嵁\n",
    "import pandas as pd\n",
    "import os\n",
    "\n",
    "# ================================\n",
    "# 1. 閰嶇疆璺緞\n",
    "# ================================\n",
    "gee_dir = r\"D:/Hospital_Pharmacy program/data/processed/controls/gee_ntl/gee_output\"\n",
    "csv_path = r\"D:/Hospital_Pharmacy program/data/processed/hospital_pharmacy/hospital_with_pharmacy_counts_registered/hospital_pharmacy_2012_2022.csv\"\n",
    "dta_path = r\"D:/Hospital_Pharmacy program/data/processed/hospital_pharmacy/hospital_with_pharmacy_counts_registered/hospital_pharmacy_2012_2022.dta\"\n",
    "\n",
    "# ================================\n",
    "# 2. 璇诲彇鎵€鏈夊勾浠絅TL鏁版嵁骞跺悎骞禱n",
    "# ================================\n",
    "ntl_list = []\n",
    "for year in range(2012, 2023):\n",
    "    f = os.path.join(gee_dir, f\"hospital_ntl_{year}.csv\")\n",
    "    if os.path.exists(f):\n",
    "        ntl = pd.read_csv(f)\n",
    "        ntl_list.append(ntl)\n",
    "        print(f\"{year}: {len(ntl)} 琛孿")\n",
    "    else:\n",
    "        print(f\"{year}: 鏂囦欢涓嶅瓨鍦╘")\n",
    "\n",
    "ntl_all = pd.concat(ntl_list, ignore_index=True)\n",
    "print(f\"\\nNTL鍚堝苟鎬昏鏁? {len(ntl_all)}\")\n",
    "\n",
    "# ================================\n",
    "# 3. 瀹芥牸寮忚浆鎹細鎸塱d+year+radius灞曞紑\n",
    "# ================================\n",
    "ntl_wide = ntl_all.pivot_table(\n",
    "    index=['id', 'year'],\n",
    "    columns='radius',\n",
    "    values=['ntl_mean', 'ntl_sum', 'ntl_pixels']\n",
    ").reset_index()\n",
    "\n",
    "# 鎵佸钩鍖栧垪鍚嶏細ntl_mean_1km, ntl_mean_2km, ntl_mean_3km 绛塡n",
    "new_cols = []\n",
    "for col in ntl_wide.columns:\n",
    "    if isinstance(col, tuple):\n",
    "        metric, radius = col\n",
    "        if radius == '':\n",
    "            new_cols.append(metric)\n",
    "        else:\n",
    "            new_cols.append(f\"{metric}_{radius}\")\n",
    "    else:\n",
    "        new_cols.append(col)\n",
    "ntl_wide.columns = new_cols\n",
    "\n",
    "# 閲嶆柊鎺掑垪鍒楀悕锛歩d, year, ntl_mean_1km/2km/3km, ntl_sum_1km/2km/3km, ntl_pixels_1km/2km/3km\n",
    "col_order = ['id', 'year']\n",
    "for r in ['1km', '2km', '3km']:\n",
    "    col_order.append(f'ntl_mean_{r}')\n",
    "for r in ['1km', '2km', '3km']:\n",
    "    col_order.append(f'ntl_sum_{r}')\n",
    "for r in ['1km', '2km', '3km']:\n",
    "    col_order.append(f'ntl_pixels_{r}')\n",
    "ntl_wide = ntl_wide[col_order]\n",
    "\n",
    "print(f\"NTL瀹芥牸寮忚鏁? {len(ntl_wide)}\")\n",
    "print(f\"NTL瀹芥牸寮忓垪鍚? {ntl_wide.columns.tolist()}\")\n",
    "\n",
    "# ================================\n",
    "# 4. 璇诲彇鐩爣闈㈡澘鏁版嵁\n",
    "# ================================\n",
    "df = pd.read_csv(csv_path, encoding='utf-8', low_memory=False)\n",
    "print(f\"\\n鐩爣闈㈡澘鏁版嵁琛屾暟: {len(df)}\")\n",
    "\n",
    "# ================================\n",
    "# 5. 浠d+year涓洪敭鍚堝苟NTL\n",
    "# ================================\n",
    "df_merged = df.merge(ntl_wide, on=['id', 'year'], how='left')\n",
    "\n",
    "matched = df_merged['ntl_mean_1km'].notna().sum()\n",
    "print(f\"鍖归厤鍒癗TL: {matched} / {len(df_merged)} ({matched/len(df_merged)*100:.1f}%)\")\n",
    "\n",
    "# ================================\n",
    "# 6. 淇濆瓨CSV\n",
    "# ================================\n",
    "df_merged.to_csv(csv_path, index=False, encoding='utf-8-sig')\n",
    "print(f\"\\n宸茶鐩朇SV: hospital_pharmacy_2012_2022.csv\")\n",
    "\n",
    "# ================================\n",
    "# 7. 淇濆瓨DTA\n",
    "# ================================\n",
    "\n",
    "df_merged.to_stata(\n",
    "    dta_path,\n",
    "    write_index=False,\n",
    "    version=118\n",
    ")\n",
    "\n",
    "print(f\"宸茶鐩朌TA: hospital_pharmacy_2012_2022.dta\")\n",
    "\n",
    "# ================================\n",
    "# 8. 杈撳嚭鏈€缁堢粨鏋淺n",
    "# ================================\n",
    "print(f\"\\n鏈€缁堣鏁? {len(df_merged)}\")\n",
    "print(f\"鏈€缁堝垪鏁? {len(df_merged.columns)}\")\n",
    "print(f\"鏂板NTL鍒? {[c for c in df_merged.columns if 'ntl_' in c]}\")"
   ]
