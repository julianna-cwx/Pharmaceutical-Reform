    "import pandas as pd\n",
    "import geopandas as gpd\n",
    "from tqdm import tqdm\n",
    "import os\n",
    "# 鏂板锛氳嚜鍔ㄦ娴嬫枃浠剁紪鐮佺殑搴揬n",
    "import chardet\n",
    "\n",
    "# 纭繚蹇呰鐨勫簱宸插畨瑁匼n",
    "try:\n",
    "    import geopandas as gpd\n",
    "    from tqdm import tqdm\n",
    "    import chardet\n",
    "except ImportError:\n",
    "    print(\"璇峰畨瑁呭繀瑕佺殑搴擄細pip install geopandas tqdm chardet\")\n",
    "    exit()\n",
    "\n",
    "def get_file_encoding(file_path):\n",
    "    \"\"\"\n",
    "    鑷姩妫€娴嬫枃浠剁紪鐮侊紙鏍稿績淇鍑芥暟锛塡n",
    "    \"\"\"\n",
    "    with open(file_path, 'rb') as f:\n",
    "        # 璇诲彇鍓?0000瀛楄妭妫€娴嬬紪鐮乗n",
    "        raw_data = f.read(10000)\n",
    "    result = chardet.detect(raw_data)\n",
    "    return result['encoding']\n",
    "\n",
    "def process_year_optimized(year):\n",
    "    try:\n",
    "        # ===================== 缁熶竴瑙勮寖鏂囦欢璺緞 =====================\n",
    "        # 璇诲彇鍖婚櫌鏁版嵁\n",
    "        hospital_path = f\"D:/Hospital_Pharmacy program/data/processed/hospital/hospital_registered/hospital_register_final_{year}.csv\"\n",
    "\n",
    "        # ===================== 鑷姩妫€娴嬬紪鐮?+ 鍏煎澶氱缂栫爜 =====================\n",
    "        # 浼樺厛鑷姩妫€娴嬬紪鐮侊紝鍏舵灏濊瘯甯哥敤缂栫爜\n",
    "        hospital_df = None\n",
    "        try:\n",
    "            # 绗竴姝ワ細鑷姩妫€娴嬬紪鐮乗n",
    "            file_encoding = get_file_encoding(hospital_path)\n",
    "            hospital_df = pd.read_csv(hospital_path, encoding=file_encoding)\n",
    "            print(f\" 鑷姩妫€娴嬩娇鐢?{file_encoding} 缂栫爜璇诲彇鍖婚櫌鏁版嵁\")\n",
    "        except:\n",
    "            # 绗簩姝ワ細鍏滃簳灏濊瘯甯哥敤缂栫爜\n",
    "            encodings = ['utf-8', 'gbk', 'gb2312', 'utf-8-sig', 'gb18030']\n",
    "            for encoding in encodings:\n",
    "                try:\n",
    "                    hospital_df = pd.read_csv(hospital_path, encoding=encoding)\n",
    "                    print(f\" 鍏滃簳浣跨敤 {encoding} 缂栫爜璇诲彇鍖婚櫌鏁版嵁\")\n",
    "                    break\n",
    "                except Exception:\n",
    "                    continue\n",
    "        \n",
    "        # 鍒ゆ柇鏂囦欢鏄惁璇诲彇鎴愬姛\n",
    "        if hospital_df is None:\n",
    "            print(f\" 鏃犳硶璇诲彇鍖婚櫌鏁版嵁鏂囦欢: {hospital_path}\")\n",
    "            return\n",
    "        \n",
    "        # 璇诲彇鑽簵鏁版嵁\n",
    "        drugstore_path = f\"D:/Hospital_Pharmacy program/data/processed/pharmacy/real_pharmacy_data/real_pharmacy_dzdp_pharmacies_{year}.csv\"\n",
    "        drugstore_df = None\n",
    "        try:\n",
    "            file_encoding = get_file_encoding(drugstore_path)\n",
    "            drugstore_df = pd.read_csv(drugstore_path, encoding=file_encoding)\n",
    "            print(f\"鑷姩妫€娴嬩娇鐢?{file_encoding} 缂栫爜璇诲彇鑽簵鏁版嵁\")\n",
    "        except:\n",
    "            encodings = ['utf-8', 'gbk', 'gb2312', 'utf-8-sig', 'gb18030']\n",
    "            for encoding in encodings:\n",
    "                try:\n",
    "                    drugstore_df = pd.read_csv(drugstore_path, encoding=encoding)\n",
    "                    print(f\"鍏滃簳浣跨敤 {encoding} 缂栫爜璇诲彇鑽簵鏁版嵁\")\n",
    "                    break\n",
    "                except Exception:\n",
    "                    continue\n",
    "        \n",
    "        if drugstore_df is None:\n",
    "            print(f\" 鏃犳硶璇诲彇鑽簵鏁版嵁鏂囦欢: {drugstore_path}\")\n",
    "            return\n",
    "        \n",
    "        # 杞崲涓?GeoDataFrame\n",
    "        hospital_gdf = gpd.GeoDataFrame(  \n",
    "            hospital_df,\n",
    "            geometry=gpd.points_from_xy(hospital_df['wgs_lon_true'], hospital_df['wgs_lat_true']),\n",
    "            crs=\"EPSG:4326\"\n",
    "        )\n",
    "        drugstore_gdf = gpd.GeoDataFrame(\n",
    "            drugstore_df,\n",
    "            geometry=gpd.points_from_xy(drugstore_df['lon_wgs'], drugstore_df['lat_wgs']),\n",
    "            crs=\"EPSG:4326\"\n",
    "        )\n",
    "        \n",
    "        # 杞崲涓烘姇褰卞潗鏍囩郴锛堝崟浣嶏細绫筹級\n",
    "        hospital_gdf = hospital_gdf.to_crs(\"EPSG:3857\")\n",
    "        drugstore_gdf = drugstore_gdf.to_crs(\"EPSG:3857\")\n",
    "        \n",
    "        # 寤虹珛绌洪棿绱㈠紩\n",
    "        drugstore_sindex = drugstore_gdf.sindex\n",
    "        \n",
    "        # 鍒濆鍖栫粺璁″垪\n",
    "        hospital_gdf['pharmacy_count_1km'] = 0\n",
    "        hospital_gdf['pharmacy_count_2km'] = 0\n",
    "        hospital_gdf['pharmacy_count_3km'] = 0\n",
    "        \n",
    "        # 閬嶅巻姣忓鍖婚櫌\n",
    "        for idx, hospital in tqdm(hospital_gdf.iterrows(), total=len(hospital_gdf), desc=f\"Processing {year}\"):\n",
    "            buffer_3km = hospital.geometry.buffer(3000)\n",
    "            possible_matches_index = list(drugstore_sindex.intersection(buffer_3km.bounds))\n",
    "            possible_matches = drugstore_gdf.iloc[possible_matches_index]\n",
    "            precise_matches = possible_matches[possible_matches.geometry.within(buffer_3km)]\n",
    "            \n",
    "            for _, pharmacy in precise_matches.iterrows():\n",
    "                distance_meters = hospital.geometry.distance(pharmacy.geometry)\n",
    "                distance_km = distance_meters / 1000\n",
    "                \n",
    "                if distance_km <= 1:\n",
    "                    hospital_gdf.at[idx, 'pharmacy_count_1km'] += 1\n",
    "                if distance_km <= 2:\n",
    "                    hospital_gdf.at[idx, 'pharmacy_count_2km'] += 1\n",
    "                if distance_km <= 3:\n",
    "                    hospital_gdf.at[idx, 'pharmacy_count_3km'] += 1\n",
    "        \n",
    "        # 杞崲鍥炲師濮嬪潗鏍囩郴\n",
    "        hospital_gdf = hospital_gdf.to_crs(\"EPSG:4326\")\n",
    "        \n",
    "        # 淇濆瓨缁撴灉\n",
    "        output_path = f\"D:/Hospital_Pharmacy program/data/processed/hospital_pharmacy/hospital_with_pharmacy_counts_registered/hospital_with_pharmacy_counts_{year}.csv\"\n",
    "        os.makedirs(os.path.dirname(output_path), exist_ok=True)\n",
    "        \n",
    "        # 淇濆瓨缂栫爜鍥哄畾涓?utf-8-sig锛孍xcel鎵撳紑鏃犱贡鐮乗n",
    "        hospital_gdf.drop(columns=['geometry']).to_csv(output_path, index=False, encoding='utf-8-sig')\n",
    "        print(f\"宸蹭繚瀛?{year} 骞寸粨鏋? {output_path}\")\n",
    "        \n",
    "        return hospital_gdf\n",
    "        \n",
    "    except Exception as e:\n",
    "        print(f\" 澶勭悊 {year} 骞存暟鎹椂鍑洪敊: {str(e)}\")\n",
    "        import traceback\n",
    "        traceback.print_exc()\n",
    "        return None\n",
    "\n",
    "# 鎵ц澶勭悊\n",
    "print(\"=\" * 50)\n",
    "print(\"寮€濮嬪鐞?012骞存暟鎹?..\")\n",
    "print(\"=\" * 50)\n",
    "\n",
    "result_2012 = process_year_optimized(2012)\n",
    "\n",
    "if result_2012 is not None:\n",
    "    print(\"\\n2012骞村鐞嗙粨鏋滈瑙?\")\n",
    "    print(\"=\" * 50)\n",
    "    print(f\"鎬诲尰闄㈡暟閲? {len(result_2012)}\")\n",
    "    print(f\"鏈?km鍐呰嵂搴楃殑鍖婚櫌鏁伴噺: {(result_2012['pharmacy_count_1km'] > 0).sum()}\")\n",
    "    print(f\"鏈?km鍐呰嵂搴楃殑鍖婚櫌鏁伴噺: {(result_2012['pharmacy_count_2km'] > 0).sum()}\")\n",
    "    print(f\"鏈?km鍐呰嵂搴楃殑鍖婚櫌鏁伴噺: {(result_2012['pharmacy_count_3km'] > 0).sum()}\")\n",
    "\n",
    "# 澶勭悊鍚庣画骞翠唤\n",
    "if result_2012 is not None:\n",
    "    print(\"\\n\" + \"=\" * 50)\n",
    "    print(\"寮€濮嬪鐞?013-2022骞存暟鎹?..\")\n",
    "    print(\"=\" * 50)\n",
    "    for year in range(2013, 2023):\n",
    "        print(f\"\\n澶勭悊 {year} 骞存暟鎹?..\")\n",
    "        process_year_optimized(year)\n",
    "    print(\"\\n 鎵€鏈夊勾浠芥暟鎹鐞嗗畬鎴愶紒\")\n",
    "else:\n",
    "    print(\"\\n 2012骞存暟鎹鐞嗗け璐ワ紝鍋滄澶勭悊鍏朵粬骞翠唤\")"
   ]
