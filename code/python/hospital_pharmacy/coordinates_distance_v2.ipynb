   "source": [
    "# county_v3: 鎸夊尯鍘夸唬鐮侊紙PAC/county_id锛夎仛鍚堬紝涓嶅啀浣跨敤 GIS 绌洪棿缂撳啿鍖篭n",
    "# 鐢ㄤ簬鍘跨骇闈㈡澘鍥炲綊锛圱WFE / CSDID / PPML锛塡n",
    "# 鐗堟湰锛氬鍔犲叕绔嬪尰闄㈠崰姣?+ 淇濈暀 policy_year锛堝彇鍖哄幙鍐呮渶灏忓€硷級\n",
    "\n",
    "import pandas as pd\n",
    "import os\n",
    "import chardet\n",
    "\n",
    "\n",
    "def get_file_encoding(file_path: str) -> str:\n",
    "    with open(file_path, \"rb\") as f:\n",
    "        raw = f.read(10000)\n",
    "    result = chardet.detect(raw)\n",
    "    return result[\"encoding\"] or \"utf-8\"\n",
    "\n",
    "\n",
    "def safe_read_csv(file_path: str, **kwargs):\n",
    "    \"\"\"渚濇灏濊瘯鑷姩妫€娴?-> utf-8-sig -> gb18030 -> latin1\"\"\"\n",
    "    try:\n",
    "        enc = get_file_encoding(file_path)\n",
    "        df = pd.read_csv(file_path, encoding=enc, **kwargs)\n",
    "        print(\"  [OK] auto {}: {}\".format(enc, file_path))\n",
    "        return df\n",
    "    except Exception:\n",
    "        pass\n",
    "    for enc in [\"utf-8-sig\", \"utf-8\", \"gb18030\", \"gbk\", \"gb2312\", \"latin1\"]:\n",
    "        try:\n",
    "            df = pd.read_csv(file_path, encoding=enc, **kwargs)\n",
    "            print(\"  [OK] fallback {}: {}\".format(enc, file_path))\n",
    "            return df\n",
    "        except Exception:\n",
    "            continue\n",
    "    print(\"  [ERR] cannot read: {}\".format(file_path))\n",
    "    return None\n",
    "\n",
    "\n",
    "def process_year_county(year: int):\n",
    "    \"\"\"\n",
    "    鎸夊尯鍘夸唬鐮佽仛鍚堣嵂搴楁暟閲忥紙county_v3 閫昏緫锛塡n",
    "    姝ラ锛歕n",
    "      1. 璇诲彇鑽簵鏁版嵁 -> 鎸?PAC 缁熻 pharmacy_count + 杩為攣\n",
    "      2. 璇诲彇鍖婚櫌鏁版嵁 -> 鎸?county_id 鑱氬悎鍖婚櫌鏁伴噺锛堝叕绔?姘戣惀锛塡n",
    "      3. 淇濈暀 policy_year锛堝彇鍖哄幙鍐呮渶灏忓€硷級锛岀敤浜庡悗缁?DID 鍥炲綊\n",
    "      4. 宸﹁繛鎺ワ紝缂哄け鑽簵濉?0\n",
    "      5. 淇濆瓨鍒嗗勾 CSV\n",
    "    \"\"\"\n",
    "    sep = \"=\" * 50\n",
    "    print(\"\\n\" + sep)\n",
    "    print(\"  county_v3 -- {}\".format(year))\n",
    "    print(sep)\n",
    "\n",
    "    pharmacy_path = (\n",
    "        \"D:/Hospital_Pharmacy program/data/processed/pharmacy/real_pharmacy_data/\"\n",
    "        \"real_pharmacy_dzdp_pharmacies_{}.csv\".format(year)\n",
    "    )\n",
    "    hospital_path = (\n",
    "        \"D:/Hospital_Pharmacy program/hospital/register data/register 2022/\"\n",
    "        \"final data/hospital_registerd/hospital_register_final_{}.csv\".format(year)\n",
    "    )\n",
    "    output_dir  = \"D:/Hospital_Pharmacy program/data/processed/hospital_pharmacy/county_pharmacy_panel\"\n",
    "    output_path = output_dir + \"/county_pharmacy_{}.csv\".format(year)\n",
    "    os.makedirs(output_dir, exist_ok=True)\n",
    "\n",
    "    # ------ 1. 鑽簵鏁版嵁 ------\n",
    "    pharmacy_df = safe_read_csv(pharmacy_path)\n",
    "    if pharmacy_df is None:\n",
    "        return None\n",
    "\n",
    "    pharmacy_df[\"PAC\"] = pd.to_numeric(pharmacy_df[\"PAC\"], errors=\"coerce\")\n",
    "    pharmacy_df = pharmacy_df[pharmacy_df[\"PAC\"].notna()].copy()\n",
    "    pharmacy_df[\"PAC\"] = pharmacy_df[\"PAC\"].astype(int)\n",
    "\n",
    "    if \"is_chains\" in pharmacy_df.columns:\n",
    "        pharmacy_df[\"is_chains_flag\"] = pharmacy_df[\"is_chains\"].apply(\n",
    "            lambda x: 1 if str(x).strip().lower() in [\"1\", \"yes\", \"true\", \"鏄痋"] else 0\n",
    "        )\n",
    "    else:\n",
    "        pharmacy_df[\"is_chains_flag\"] = 0\n",
    "\n",
    "    county_pharmacy = (\n",
    "        pharmacy_df\n",
    "        .groupby(\"PAC\")\n",
    "        .agg(\n",
    "            pharmacy_count       = (\"PAC\",            \"count\"),\n",
    "            chain_pharmacy_count = (\"is_chains_flag\", \"sum\"),\n",
    "        )\n",
    "        .reset_index()\n",
    "    )\n",
    "    county_pharmacy[\"chain_share\"] = (\n",
    "        county_pharmacy[\"chain_pharmacy_count\"] /\n",
    "        county_pharmacy[\"pharmacy_count\"].replace(0, pd.NA)\n",
    "    )\n",
    "    print(\"  鑽簵: {} 鏉? {} 涓尯鍘縗".format(len(pharmacy_df), len(county_pharmacy)))\n",
    "\n",
    "    # ------ 2. 鍖婚櫌鏁版嵁 ------\n",
    "    hospital_df = safe_read_csv(hospital_path)\n",
    "    if hospital_df is None:\n",
    "        return None\n",
    "\n",
    "    hospital_df[\"county_id\"] = pd.to_numeric(hospital_df[\"county_id\"], errors=\"coerce\")\n",
    "    hospital_df = hospital_df[hospital_df[\"county_id\"].notna()].copy()\n",
    "    hospital_df[\"county_id\"] = hospital_df[\"county_id\"].astype(int)\n",
    "\n",
    "    # 澶勭悊 policy_year锛氳浆鏁板€糪n",
    "    has_policy_year = False\n",
    "    if \"policy_year\" in hospital_df.columns:\n",
    "        hospital_df[\"policy_year\"] = pd.to_numeric(hospital_df[\"policy_year\"], errors=\"coerce\")\n",
    "        has_policy_year = True\n",
    "\n",
    "    county_hospital = (\n",
    "        hospital_df\n",
    "        .groupby(\"county_id\")\n",
    "        .agg(hospital_count=(\"id\", \"count\"))\n",
    "        .reset_index()\n",
    "    )\n",
    "\n",
    "    # 鑱氬悎 policy_year锛氬彇鍖哄幙鍐呮渶鏃╃殑鏀跨瓥瀹炴柦骞翠唤锛堟渶灏忓€硷級\n",
    "    if has_policy_year:\n",
    "        policy_agg = (\n",
    "            hospital_df\n",
    "            .groupby(\"county_id\")[\"policy_year\"]\n",
    "            .min()\n",
    "            .reset_index()\n",
    "        )\n",
    "        # 鑻ヨ鍖哄幙鎵€鏈夊尰闄?policy_year 鍧囩己澶憋紝鍒?policy_year = NaN\n",
    "        county_hospital = county_hospital.merge(policy_agg, on=\"county_id\", how=\"left\")\n",
    "        print(\"  policy_year 宸茶仛鍚堬紙鍙栧尯鍘垮唴鏈€灏忓€硷級\")\n",
    "\n",
    "    # 鍏珛/姘戣惀鍒嗙被 + 鍏珛鍖婚櫌鍗犳瘮\n",
    "    if \"浼佷笟缁忚惀鏂瑰紡\" in hospital_df.columns:\n",
    "        pivot = (\n",
    "            hospital_df\n",
    "            .groupby([\"county_id\", \"浼佷笟缁忚惀鏂瑰紡\"])\n",
    "            .size()\n",
    "            .unstack(fill_value=0)\n",
    "            .reset_index()\n",
    "        )\n",
    "        pivot.columns = [\"county_id\"] + [\"hospital_{}\".format(c) for c in pivot.columns[1:]]\n",
    "        county_hospital = county_hospital.merge(pivot, on=\"county_id\", how=\"left\")\n",
    "\n",
    "        # 璁＄畻鍏珛鍖婚櫌鍗犳瘮\n",
    "        if \"hospital_鍏珛\" in county_hospital.columns:\n",
    "            county_hospital[\"public_hospital_share\"] = (\n",
    "                county_hospital[\"hospital_鍏珛\"].fillna(0)\n",
    "                / county_hospital[\"hospital_count\"].replace(0, pd.NA)\n",
    "            ).fillna(0)\n",
    "        else:\n",
    "            private_cols = [c for c in pivot.columns[1:] if \"姘戣惀\" in c or \"绉佷汉\" in c]\n",
    "            if private_cols:\n",
    "                private_total = county_hospital[private_cols].sum(axis=1).fillna(0)\n",
    "                county_hospital[\"public_hospital_share\"] = (\n",
    "                    (county_hospital[\"hospital_count\"] - private_total).clip(lower=0)\n",
    "                    / county_hospital[\"hospital_count\"].replace(0, pd.NA)\n",
    "                ).fillna(0)\n",
    "            else:\n",
    "                county_hospital[\"public_hospital_share\"] = 0\n",
    "    else:\n",
    "        county_hospital[\"public_hospital_share\"] = 0\n",
    "\n",
    "    # 鐪?甯?鍖哄幙鍏冧俊鎭痋n",
    "    meta_cols = [c for c in [\"鐪佷唤\", \"鍩庡競\", \"鍖哄幙\"] if c in hospital_df.columns]\n",
    "    if meta_cols:\n",
    "        county_meta = (\n",
    "            hospital_df\n",
    "            .groupby(\"county_id\")[meta_cols]\n",
    "            .first()\n",
    "            .reset_index()\n",
    "        )\n",
    "        county_hospital = county_hospital.merge(county_meta, on=\"county_id\", how=\"left\")\n",
    "\n",
    "    print(\"  鍖婚櫌: {} 鏉? {} 涓尯鍘縗".format(len(hospital_df), len(county_hospital)))\n",
    "\n",
    "    # ------ 3. 宸﹁繛鎺ュ悎骞?------\n",
    "    result = county_hospital.merge(\n",
    "        county_pharmacy, left_on=\"county_id\", right_on=\"PAC\", how=\"left\"\n",
    "    )\n",
    "    result[\"pharmacy_count\"]        = result[\"pharmacy_count\"].fillna(0).astype(int)\n",
    "    result[\"chain_pharmacy_count\"]  = result[\"chain_pharmacy_count\"].fillna(0).astype(int)\n",
    "    result[\"chain_share\"]           = result[\"chain_share\"].fillna(0)\n",
    "    result[\"public_hospital_share\"] = result[\"public_hospital_share\"].fillna(0)\n",
    "\n",
    "    # policy_year锛氶潪缂哄け鍊艰浆 int锛岀己澶卞€间繚鐣?NaN锛堟帶鍒剁粍锛塡n",
    "    if has_policy_year and \"policy_year\" in result.columns:\n",
    "        mask = result[\"policy_year\"].notna()\n",
    "        result.loc[mask, \"policy_year\"] = result.loc[mask, \"policy_year\"].astype(int)\n",
    "        # 鎺у埗缁勫尯鍘?policy_year = NaN锛孲tata 瀛樹负 .\n",
    "\n",
    "    if \"PAC\" in result.columns:\n",
    "        result.drop(columns=[\"PAC\"], inplace=True)\n",
    "\n",
    "    result.insert(0, \"year\", year)\n",
    "\n",
    "    # ------ 4. 淇濆瓨 ------\n",
    "    result.to_csv(output_path, index=False, encoding=\"utf-8-sig\")\n",
    "    print(\"  [SAVED] {}\".format(output_path))\n",
    "    return result\n",
    "\n",
    "\n",
    "# ================================\n",
    "# 涓绘祦绋?2012-2022\n",
    "# ================================\n",
    "all_results = []\n",
    "\n",
    "for year in range(2012, 2023):\n",
    "    df = process_year_county(year)\n",
    "    if df is not None:\n",
    "        all_results.append(df)\n",
    "\n",
    "print(\"\\ncounty_v3 鎵€鏈夊勾浠藉鐞嗗畬鎴愶紒\")\n"
