  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e14eb5ee",
   "metadata": {},
   "outputs": [],
   "source": [
    "# v2鏂板锛氬湪宸ュ晢鍧愭爣濉ˉ鍜岀己澶卞潗鏍囧鍑轰箣鍚庤繍琛屻€俓n",
    "# 鍔熻兘锛氭寜鍖婚櫌鍚嶇О ENTNAME 鍖归厤鎵嬪姩鏌ヨ鍧愭爣锛岃浆鎹负 WGS84 鍚庡彟瀛樹负 hospital_wgs84_final_all.csv銆俓n",
    "import shutil\n",
    "from datetime import datetime\n",
    "from pathlib import Path\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import eviltransform\n",
    "\n",
    "# 涓枃鍒楀悕浣跨敤 Unicode 杞箟锛岄伩鍏嶄笉鍚岀粓绔?缂栬緫鍣ㄩ€犳垚缂栫爜闂銆俓n",
    "COL_BD_LON = \"\\u767e\\u5ea6\\u7ecf\\u5ea6_\\u624b\\u52a8\\u67e5\\u8be2\"\n",
    "COL_BD_LAT = \"\\u767e\\u5ea6\\u7eac\\u5ea6_\\u624b\\u52a8\\u67e5\\u8be2\"\n",
    "COL_GD_LON = \"\\u9ad8\\u5fb7\\u7ecf\\u5ea6_\\u624b\\u52a8\\u67e5\\u8be2\"\n",
    "COL_GD_LAT = \"\\u9ad8\\u5fb7\\u7eac\\u5ea6_\\u624b\\u52a8\\u67e5\\u8be2\"\n",
    "\n",
    "base_dir = Path(r\"D:\\Hospital_Pharmacy program\\data\\processed\\hospital\\hospital_registered\")\n",
    "manual_files = [\n",
    "    base_dir / \"handed_coordinates_part5-3601.xlsx\",\n",
    "    base_dir / (\"handed_coordinates_part5_\" + \"\\u540e\\u534a\\u90e8\\u5206-11day.xlsx\"),\n",
    "]\n",
    "\n",
    "# 璇诲彇宸ュ晢鍧愭爣濉ˉ鍚庣殑闃舵鏂囦欢锛涙墜鍔ㄥ潗鏍囧～鍏呭悗鐨勫悎骞剁粨鏋滃彟瀛樹负 final_all 鏂囦欢銆俓n",
    "input_file = base_dir / \"hospital_wgs84_final_with_score.csv\"\n",
    "output_file = r\"D:\\Hospital_Pharmacy program\\data\\processed\\hospital\\hospital_registered\\hospital_wgs84_final_all.csv\"\n",
    "output_file = Path(output_file)\n",
    "missing_file = base_dir / \"hospital_wgs84_missing_coords.csv\"\n",
    "backup_file = base_dir / f\"hospital_wgs84_final_all_before_overwrite_{datetime.now():%Y%m%d_%H%M%S}.csv\"\n",
    "audit_file = base_dir / \"hospital_wgs84_final_all_manual_fill_audit_by_name.csv\"\n",
    "\n",
    "\n",
    "def clean_coord(series):\n",
    "    \"\"\"鎶婃墜鍔ㄥ綍鍏ョ殑鍧愭爣杞垚鏁板€硷紝骞跺吋瀹规湯灏鹃€楀彿銆佷腑鏂囬€楀彿鍜岀┖鍗曞厓鏍笺€俓"\"\"\n",
    "    return pd.to_numeric(\n",
    "        series.astype(str)\n",
    "        .str.strip()\n",
    "        .str.replace(\"\\uff0c\", \",\", regex=False)\n",
    "        .str.replace(\",\", \"\", regex=False)\n",
    "        .replace({\"nan\": np.nan, \"None\": np.nan, \"\": np.nan}),\n",
    "        errors=\"coerce\",\n",
    "    )\n",
    "\n",
    "\n",
    "def is_valid_lon_lat(lon, lat):\n",
    "    return lon.notna() & lat.notna() & lon.between(-180, 180) & lat.between(-90, 90)\n",
    "\n",
    "\n",
    "def bd09_to_wgs84(lon, lat):\n",
    "    \"\"\"鐧惧害 BD-09 杞?WGS84锛沞viltransform 鐨勮緭鍏ュ拰杩斿洖椤哄簭閮芥槸绾害銆佺粡搴︺€俓"\"\"\n",
    "    if pd.isna(lon) or pd.isna(lat):\n",
    "        return np.nan, np.nan\n",
    "    wgs_lat, wgs_lon = eviltransform.bd2wgs(lat, lon)\n",
    "    return wgs_lon, wgs_lat\n",
    "\n",
    "\n",
    "def gcj02_to_wgs84(lon, lat):\n",
    "    \"\"\"楂樺痉 GCJ-02 杞?WGS84锛沞viltransform 鐨勮緭鍏ュ拰杩斿洖椤哄簭閮芥槸绾害銆佺粡搴︺€俓"\"\"\n",
    "    if pd.isna(lon) or pd.isna(lat):\n",
    "        return np.nan, np.nan\n",
    "    wgs_lat, wgs_lon = eviltransform.gcj2wgs(lat, lon)\n",
    "    return wgs_lon, wgs_lat\n",
    "\n",
    "\n",
    "def read_csv_auto(path):\n",
    "    for enc in [\"utf-8-sig\", \"gb18030\", \"utf-8\", \"gbk\"]:\n",
    "        try:\n",
    "            return pd.read_csv(path, encoding=enc, low_memory=False), enc\n",
    "        except UnicodeDecodeError:\n",
    "            continue\n",
    "    raise ValueError(f\"Could not read CSV with expected encodings: {path}\")\n",
    "\n",
    "\n",
    "manual_parts = []\n",
    "for manual_file in manual_files:\n",
    "    sheets = pd.read_excel(manual_file, sheet_name=None)\n",
    "    for sheet_name, df_sheet in sheets.items():\n",
    "        df_sheet = df_sheet.copy()\n",
    "        df_sheet[\"_manual_file\"] = manual_file.name\n",
    "        df_sheet[\"_manual_sheet\"] = sheet_name\n",
    "        df_sheet[\"_manual_row\"] = np.arange(2, len(df_sheet) + 2)\n",
    "        manual_parts.append(df_sheet)\n",
    "\n",
    "manual = pd.concat(manual_parts, ignore_index=True)\n",
    "manual[\"ENTNAME\"] = manual[\"ENTNAME\"].astype(str).str.strip()\n",
    "\n",
    "for col in [COL_BD_LON, COL_BD_LAT, COL_GD_LON, COL_GD_LAT]:\n",
    "    manual[col] = clean_coord(manual[col])\n",
    "\n",
    "has_baidu = is_valid_lon_lat(manual[COL_BD_LON], manual[COL_BD_LAT])\n",
    "has_gaode = is_valid_lon_lat(manual[COL_GD_LON], manual[COL_GD_LAT])\n",
    "\n",
    "manual[[\"baidu_manual_wgs_lon\", \"baidu_manual_wgs_lat\"]] = manual.apply(\n",
    "    lambda row: bd09_to_wgs84(row[COL_BD_LON], row[COL_BD_LAT]),\n",
    "    axis=1,\n",
    "    result_type=\"expand\",\n",
    ")\n",
    "manual[[\"gaode_manual_wgs_lon\", \"gaode_manual_wgs_lat\"]] = manual.apply(\n",
    "    lambda row: gcj02_to_wgs84(row[COL_GD_LON], row[COL_GD_LAT]),\n",
    "    axis=1,\n",
    "    result_type=\"expand\",\n",
    ")\n",
    "\n",
    "# 鍧愭爣閫夋嫨浼樺厛绾э細鍏堢敤鐧惧害鎵嬪姩鍧愭爣锛涚櫨搴︾己澶辨椂鐢ㄩ珮寰锋墜鍔ㄥ潗鏍囷紱涓よ€呴兘缂哄け鍒欎繚鐣欑┖鍊笺€俓n",
    "manual[\"manual_source\"] = np.select(\n",
    "    [has_baidu, has_gaode],\n",
    "    [\"baidu_manual\", \"gaode_manual\"],\n",
    "    default=pd.NA,\n",
    ")\n",
    "manual[\"manual_wgs_lon\"] = np.select(\n",
    "    [has_baidu, has_gaode],\n",
    "    [manual[\"baidu_manual_wgs_lon\"], manual[\"gaode_manual_wgs_lon\"]],\n",
    "    default=np.nan,\n",
    ")\n",
    "manual[\"manual_wgs_lat\"] = np.select(\n",
    "    [has_baidu, has_gaode],\n",
    "    [manual[\"baidu_manual_wgs_lat\"], manual[\"gaode_manual_wgs_lat\"]],\n",
    "    default=np.nan,\n",
    ")\n",
    "manual[\"_source_priority\"] = np.select([has_baidu, has_gaode], [0, 1], default=2)\n",
    "\n",
    "manual_lookup = (\n",
    "    manual.sort_values([\"ENTNAME\", \"_source_priority\", \"_manual_file\", \"_manual_row\"])\n",
    "    .drop_duplicates(subset=[\"ENTNAME\"], keep=\"first\")\n",
    "    .reset_index(drop=True)\n",
    ")\n",
    "\n",
    "hospital, hospital_encoding = read_csv_auto(input_file)\n",
    "hospital[\"ENTNAME\"] = hospital[\"ENTNAME\"].astype(str).str.strip()\n",
    "backed_up = output_file.exists()\n",
    "if backed_up:\n",
    "    shutil.copy2(output_file, backup_file)\n",
    "\n",
    "before_missing = (hospital[\"wgs_lon_true\"].isna() | hospital[\"wgs_lat_true\"].isna()).sum()\n",
    "\n",
    "manual_lookup_for_merge = manual_lookup[[\n",
    "    \"ENTNAME\", \"companyid\", \"manual_source\", \"manual_wgs_lon\", \"manual_wgs_lat\",\n",
    "    \"_manual_file\", \"_manual_sheet\", \"_manual_row\",\n",
    "    COL_BD_LON, COL_BD_LAT, COL_GD_LON, COL_GD_LAT,\n",
    "]].rename(columns={\"ENTNAME\": \"manual_ENTNAME\", \"companyid\": \"manual_companyid\"})\n",
    "\n",
    "merged = hospital.merge(\n",
    "    manual_lookup_for_merge,\n",
    "    left_on=\"ENTNAME\",\n",
    "    right_on=\"manual_ENTNAME\",\n",
    "    how=\"left\",\n",
    ")\n",
    "\n",
    "fill_mask = (\n",
    "    (merged[\"wgs_lon_true\"].isna() | merged[\"wgs_lat_true\"].isna())\n",
    "    & merged[\"manual_wgs_lon\"].notna()\n",
    "    & merged[\"manual_wgs_lat\"].notna()\n",
    ")\n",
    "\n",
    "merged.loc[fill_mask, \"wgs_lon_true\"] = merged.loc[fill_mask, \"manual_wgs_lon\"]\n",
    "merged.loc[fill_mask, \"wgs_lat_true\"] = merged.loc[fill_mask, \"manual_wgs_lat\"]\n",
    "\n",
    "# 浠呭綋 score 涓虹┖鏃剁粰鎵嬪姩濉厖鍧愭爣鏍囪鍒嗘暟锛涗笉瑕嗙洊宸叉湁 score銆俓n",
    "if \"score\" in merged.columns:\n",
    "    merged.loc[fill_mask & merged[\"score\"].isna(), \"score\"] = 9\n",
    "\n",
    "after_missing = (merged[\"wgs_lon_true\"].isna() | merged[\"wgs_lat_true\"].isna()).sum()\n",
    "\n",
    "audit = merged.loc[fill_mask, [\n",
    "    \"companyid\", \"ENTNAME\", \"manual_companyid\", \"manual_ENTNAME\", \"manual_source\",\n",
    "    \"manual_wgs_lon\", \"manual_wgs_lat\",\n",
    "    COL_BD_LON, COL_BD_LAT, COL_GD_LON, COL_GD_LAT,\n",
    "    \"_manual_file\", \"_manual_sheet\", \"_manual_row\",\n",
    "]].copy()\n",
    "\n",
    "hospital_output = merged[hospital.columns].copy()\n",
    "hospital_output.to_csv(output_file, index=False, encoding=\"utf-8-sig\")\n",
    "\n",
    "missing_coord_df = hospital_output[hospital_output[\"wgs_lon_true\"].isna() | hospital_output[\"wgs_lat_true\"].isna()].copy()\n",
    "missing_coord_df.to_csv(missing_file, index=False, encoding=\"utf-8-sig\")\n",
    "audit.to_csv(audit_file, index=False, encoding=\"utf-8-sig\")\n",
    "\n",
    "print(\"manual coordinate fill finished\")\n",
    "print(f\"hospital file encoding used: {hospital_encoding}\")\n",
    "print(f\"backup file if output existed: {backup_file if backed_up else 'no previous output file'}\")\n",
    "print(f\"input hospital file: {input_file}\")\n",
    "print(f\"output hospital file: {output_file}\")\n",
    "print(f\"refreshed missing file: {missing_file}\")\n",
    "print(f\"audit file: {audit_file}\")\n",
    "print(f\"manual unique hospitals: {len(manual_lookup)}\")\n",
    "print(f\"manual hospitals using Baidu: {(manual_lookup['manual_source'] == 'baidu_manual').sum()}\")\n",
    "print(f\"manual hospitals using Gaode: {(manual_lookup['manual_source'] == 'gaode_manual').sum()}\")\n",
    "print(f\"missing rows before fill: {before_missing}\")\n",
    "print(f\"rows filled by ENTNAME: {fill_mask.sum()}\")\n",
    "print(f\"missing rows after fill: {after_missing}\")\n",
    "print(\"filled source counts:\")\n",
    "print(audit[\"manual_source\"].value_counts(dropna=False))\n"
   ]
  },
