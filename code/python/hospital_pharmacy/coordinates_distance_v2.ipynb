   "source": [
    "import os\n",
    "import pickle\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import chardet\n",
    "from rapidfuzz import process\n",
    "\n",
    "\n",
    "# ------------------------------\n",
    "# 鍙傛暟璁剧疆\n",
    "# ------------------------------\n",
    "BASE_DIR = r\"D:\\Hospital_Pharmacy program\\data\\processed\\hospital\\coordinates_place_api\"\n",
    "\n",
    "THRESHOLD_ACCURATE = 500      # 鈮?00m 璁や负涓€鑷碶n",
    "THRESHOLD_GEOCODE = 500       # >500m 杩涘叆閫嗗湴鐞嗙紪鐮乗n",
    "FUZZY_SCORE_THRESHOLD = 80    # 妯＄硦鍖归厤闃堝€糪n",
    "\n",
    "GEOCODE_CACHE_FILE = os.path.join(BASE_DIR, \"geocode_cache.pkl\")\n",
    "\n",
    "\n",
    "# ------------------------------\n",
    "# 缂撳瓨宸ュ叿\n",
    "# ------------------------------\n",
    "def load_geocode_cache():\n",
    "    if os.path.exists(GEOCODE_CACHE_FILE):\n",
    "        try:\n",
    "            with open(GEOCODE_CACHE_FILE, \"rb\") as f:\n",
    "                return pickle.load(f)\n",
    "        except Exception:\n",
    "            return {}\n",
    "    return {}\n",
    "\n",
    "\n",
    "def save_geocode_cache(cache):\n",
    "    with open(GEOCODE_CACHE_FILE, \"wb\") as f:\n",
    "        pickle.dump(cache, f)\n",
    "\n",
    "\n",
    "def get_address_details_with_cache(lat, lng, cache):\n",
    "    key = f\"{lat:.6f},{lng:.6f}\"\n",
    "    if key in cache:\n",
    "        return cache[key]\n",
    "\n",
    "    addr = get_address_details(lat, lng)\n",
    "    cache[key] = addr\n",
    "\n",
    "    if len(cache) % 10 == 0:\n",
    "        save_geocode_cache(cache)\n",
    "\n",
    "    return addr\n",
    "\n",
    "\n",
    "# ------------------------------\n",
    "# 瑙勫垯 #1锛?00m 鍐呯洿鎺ラ€夌櫨搴n",
    "# ------------------------------\n",
    "df_merged[\"wgs_lon_true\"] = np.where(\n",
    "    df_merged[\"distance\"] <= THRESHOLD_ACCURATE,\n",
    "    df_merged[\"鐧惧害_wgs84缁忓害1\"],\n",
    "    np.nan\n",
    ")\n",
    "\n",
    "df_merged[\"wgs_lat_true\"] = np.where(\n",
    "    df_merged[\"distance\"] <= THRESHOLD_ACCURATE,\n",
    "    df_merged[\"鐧惧害_wgs84绾害1\"],\n",
    "    np.nan\n",
    ")\n",
    "\n",
    "df_merged[\"true_source\"] = np.where(\n",
    "    df_merged[\"distance\"] <= THRESHOLD_ACCURATE,\n",
    "    \"baidu\",\n",
    "    \"\"\n",
    ")\n",
    "\n",
    "\n",
    "# ------------------------------\n",
    "# 瑙勫垯 #2锛?500m 鐨勮繘鍏ラ€嗗湴鐞嗙紪鐮乗n",
    "# ------------------------------\n",
    "large_deviation = df_merged[df_merged[\"distance\"] > THRESHOLD_GEOCODE].copy()\n",
    "\n",
    "geocode_cache = load_geocode_cache()\n",
    "\n",
    "large_deviation[\"gd_address\"] = large_deviation.progress_apply(\n",
    "    lambda row: get_address_details_with_cache(\n",
    "        row[\"楂樺痉_wgs84绾害\"],\n",
    "        row[\"楂樺痉_wgs84缁忓害\"],\n",
    "        geocode_cache\n",
    "    ),\n",
    "    axis=1\n",
    ")\n",
    "\n",
    "large_deviation[\"bd_address\"] = large_deviation.progress_apply(\n",
    "    lambda row: get_address_details_with_cache(\n",
    "        row[\"鐧惧害_wgs84绾害1\"],\n",
    "        row[\"鐧惧害_wgs84缁忓害1\"],\n",
    "        geocode_cache\n",
    "    ),\n",
    "    axis=1\n",
    ")\n",
    "\n",
    "save_geocode_cache(geocode_cache)\n",
    "\n",
    "\n",
    "# ------------------------------\n",
    "# 鎻愬彇 amenity\n",
    "# ------------------------------\n",
    "def extract_amenity(addr):\n",
    "    return addr.get(\"amenity\", \"\") if isinstance(addr, dict) else \"\"\n",
    "\n",
    "\n",
    "large_deviation[\"gd_amenity\"] = large_deviation[\"gd_address\"].apply(extract_amenity)\n",
    "large_deviation[\"bd_amenity\"] = large_deviation[\"bd_address\"].apply(extract_amenity)\n",
    "\n",
    "large_deviation[\"gd_amenity_clean\"] = np.where(\n",
    "    large_deviation[\"gd_amenity\"].str.contains(\"鍖婚櫌\", na=False),\n",
    "    large_deviation[\"gd_amenity\"],\n",
    "    \"\"\n",
    ")\n",
    "\n",
    "large_deviation[\"bd_amenity_clean\"] = np.where(\n",
    "    large_deviation[\"bd_amenity\"].str.contains(\"鍖婚櫌\", na=False),\n",
    "    large_deviation[\"bd_amenity\"],\n",
    "    \"\"\n",
    ")\n",
    "\n",
    "\n",
    "# ------------------------------\n",
    "# 妯＄硦鍖归厤寰楀垎\n",
    "# ------------------------------\n",
    "def fuzzy_score(item, name):\n",
    "    if not item or not name:\n",
    "        return 0\n",
    "    match = process.extractOne(item, [name])\n",
    "    return match[1] if match else 0\n",
    "\n",
    "\n",
    "large_deviation[\"gd_match_score\"] = [\n",
    "    fuzzy_score(a, n)\n",
    "    for a, n in zip(large_deviation[\"gd_amenity_clean\"], large_deviation[\"ENTNAME\"])\n",
    "]\n",
    "\n",
    "large_deviation[\"bd_match_score\"] = [\n",
    "    fuzzy_score(a, n)\n",
    "    for a, n in zip(large_deviation[\"bd_amenity_clean\"], large_deviation[\"ENTNAME\"])\n",
    "]\n",
    "\n",
    "\n",
    "# ------------------------------\n",
    "# 瑙勫垯 #3锛氭ā绯婂尮閰?鈮?80 鐨勫潗鏍囪璁や负鍙俊\n",
    "# ------------------------------\n",
    "def choose_coord(row):\n",
    "    gd_ok = row[\"gd_match_score\"] >= FUZZY_SCORE_THRESHOLD\n",
    "    bd_ok = row[\"bd_match_score\"] >= FUZZY_SCORE_THRESHOLD\n",
    "\n",
    "    if gd_ok and (row[\"gd_match_score\"] >= row[\"bd_match_score\"]):\n",
    "        return row[\"楂樺痉_wgs84缁忓害\"], row[\"楂樺痉_wgs84绾害\"], \"gaode\"\n",
    "    if bd_ok:\n",
    "        return row[\"鐧惧害_wgs84缁忓害1\"], row[\"鐧惧害_wgs84绾害1\"], \"baidu\"\n",
    "\n",
    "    return np.nan, np.nan, \"\"\n",
    "\n",
    "\n",
    "chosen = large_deviation.apply(choose_coord, axis=1, result_type=\"expand\")\n",
    "chosen.columns = [\"wgs_lon_true\", \"wgs_lat_true\", \"true_source\"]\n",
    "\n",
    "large_deviation[chosen.columns] = chosen\n",
    "\n",
    "\n",
    "# ------------------------------\n",
    "# 鍥炲啓鍒颁富鏁版嵁\n",
    "# ------------------------------\n",
    "df_merged.update(\n",
    "    large_deviation[[\"wgs_lon_true\", \"wgs_lat_true\", \"true_source\"]]\n",
    ")\n",
    "\n",
    "\n",
    "# ------------------------------\n",
    "# 淇濆瓨缁撴灉\n",
    "# ------------------------------\n",
    "df_merged.to_csv(\n",
    "    os.path.join(BASE_DIR, \"hospital_wgs84_place_result.csv\"),\n",
    "    index=False,\n",
    "    encoding=\"utf-8-sig\"\n",
    ")\n",
    "\n",
    "large_deviation.to_csv(\n",
    "    os.path.join(BASE_DIR, \"large_deviation_with_match_place.csv\"),\n",
    "    index=False,\n",
    "    encoding=\"utf-8-sig\"\n",
    ")\n",
    "\n",
    "print(\"鍧愭爣绛涢€変笌鍖归厤娴佺▼瀹屾垚\")\n"
   ]
