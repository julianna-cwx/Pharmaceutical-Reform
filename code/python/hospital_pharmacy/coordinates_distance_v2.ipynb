    "    濉厖鈥滃勾浠解€濆垪锛孿n",
    "    \"\"\"\n",
    "\n",
    "    # ===================== 1. 璇诲彇鏁版嵁 =====================\n",
    "    print(\"姝ｅ湪妫€娴嬫枃浠剁紪鐮?..\")\n",
    "    encoding = detect_file_encoding(input_file)\n",
    "    print(f\"妫€娴嬪埌鏂囦欢缂栫爜: {encoding}\")\n",
    "\n",
    "    try:\n",
    "        df = pd.read_csv(input_file, encoding='GB18030')\n",
    "    except Exception as e:\n",
    "        print(f\"GB18030 璇诲彇澶辫触锛屾敼鐢ㄦ娴嬬紪鐮侊細{e}\")\n",
    "        df = pd.read_csv(input_file, encoding=encoding)\n",
    "\n",
    "    print(f\"鎴愬姛璇诲彇鏁版嵁锛歿df.shape[0]} 琛岋紝{df.shape[1]} 鍒梊")\n",
    "\n",
    "    # ===================== 2. 鏃ユ湡瀛楁澶勭悊 =====================\n",
    "    print(\"姝ｅ湪杞崲鏃ユ湡瀛楁...\")\n",
    "    df['鎴愮珛鏃ユ湡'] = pd.to_datetime(df['鎴愮珛鏃ユ湡'], errors='coerce')\n",
    "    df['娉ㄩ攢鏃ユ湡'] = pd.to_datetime(df['娉ㄩ攢鏃ユ湡'], errors='coerce')\n",
    "    df['鍚婇攢鏃ユ湡'] = pd.to_datetime(df['鍚婇攢鏃ユ湡'], errors='coerce')\n",
    "\n",
    "    # 纭繚杈撳嚭鐩綍瀛樺湪\n",
    "    os.makedirs(output_dir, exist_ok=True)\n",
    "\n",
    "    # ===================== 4. 鎸夊勾浠界敓鎴愨€滃瓨缁尰闄⑩€?=====================\n",
    "    print(\"寮€濮嬫寜骞翠唤鐢熸垚鍖婚櫌瀛橀噺鏁版嵁...\")\n",
    "\n",
    "    for year in range(2012, 2023):\n",
    "        year_end = pd.Timestamp(f\"{year}-12-31\")\n",
    "\n",
    "        year_df = df[\n",
    "            (df['鎴愮珛鏃ユ湡'] <= year_end) &\n",
    "            (df['娉ㄩ攢鏃ユ湡'].isna() | (df['娉ㄩ攢鏃ユ湡'] > year_end)) &\n",
    "            (df['鍚婇攢鏃ユ湡'].isna() | (df['鍚婇攢鏃ユ湡'] > year_end))\n",
    "        ].copy()\n",
    "\n",
    "        # 濉厖骞翠唤鍒梊n",
    "        year_df['骞翠唤'] = year\n",
    "\n",
    "        output_file = os.path.join(\n",
    "            output_dir,\n",
    "            f\"hospital_register_final_{year}.csv\"\n",
    "        )\n",
    "\n",
    "        year_df.to_csv(output_file, index=False, encoding='GB18030')\n",
    "\n",
    "\n",
    "    print(\"鍏ㄩ儴骞翠唤鏁版嵁鐢熸垚瀹屾垚锛乗")\n",
    "\n",
    "\n",
    "# ===================== 涓绘墽琛屽叆鍙?=====================\n",
