    "THRESHOLD = 3_000_000  # 3000 km锛岀悊璁轰笂寮傚父鍊糪n",
    "large_deviation = df_merged[df_merged[\"distance\"] > THRESHOLD]\n",
    "\n",
    "print(f\"鍋忓樊瓒呰繃 {THRESHOLD} 绫崇殑璁板綍鏈?{len(large_deviation)} 鏉")\n"
   ]
