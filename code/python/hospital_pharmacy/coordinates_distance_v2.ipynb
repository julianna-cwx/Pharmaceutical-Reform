    "#鍔犲叆宸ュ晢鏁版嵁鍧愭爣锛岃缃川閲忓垎score\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "file_path = r\"D:\\Hospital_Pharmacy program\\data\\processed\\hospital\\hospital_registered\\hospital_wgs84_final_registered_filled.csv\"\n",
    "\n",
    "# 璇诲彇\n",
    "df = pd.read_csv(file_path, encoding=\"gb18030\")\n",
    "\n",
    "# 鍒涘缓score鍒梊n",
    "df[\"score\"] = np.nan\n",
    "\n",
    "# 鏉′欢1锛氬凡鏈塛GS84鍧愭爣\n",
    "cond1 = df[\"wgs_lon_true\"].notna() & df[\"wgs_lat_true\"].notna()\n",
    "df.loc[cond1, \"score\"] = 10\n",
    "\n",
    "# 鏉′欢2锛歐GS84鍧愭爣涓虹┖锛屼絾宸ュ晢鍧愭爣瀛樺湪\n",
    "cond2 = (\n",
    "    df[\"wgs_lon_true\"].isna() &\n",
    "    df[\"wgs_lat_true\"].isna() &\n",
    "    df[\"宸ュ晢缁忓害\"].notna() &\n",
    "    df[\"宸ュ晢绾害\"].notna()\n",
    ")\n",
    "\n",
    "\n",
    "#杞崲鍧愭爣锛屽伐鍟嗘暟鎹€斺€擶GS鍧愭爣\n",
    "\n",
    "def gcj2wgs(lng, lat):\n",
    "    if pd.isna(lng) or pd.isna(lat):\n",
    "        return None, None\n",
    "    wgs_lat, wgs_lng = eviltransform.gcj2wgs(lat, lng)\n",
    "    return wgs_lng, wgs_lat\n",
    "\n",
    "# ===================== 杞崲 =====================\n",
    "# 宸ュ晢缁忓害 / 宸ュ晢绾害 鈫?杞垚 鈫?宸ュ晢_wgs84缁忓害 / 宸ュ晢_wgs84绾害\n",
    "df[[\"宸ュ晢_wgs84缁忓害\", \"宸ュ晢_wgs84绾害\"]] = df.apply(\n",
    "    lambda row: gcj2wgs(row[\"宸ュ晢缁忓害\"], row[\"宸ュ晢绾害\"]), axis=1, result_type=\"expand\"\n",
    ")\n",
    "\n",
    "# 濉ˉ鍧愭爣\n",
    "df.loc[cond2, \"wgs_lon_true\"] = df.loc[cond2, \"宸ュ晢_wgs84缁忓害\"]\n",
    "df.loc[cond2, \"wgs_lat_true\"] = df.loc[cond2, \"宸ュ晢_wgs84绾害\"]\n",
    "\n",
    "# 璁剧疆score\n",
    "df.loc[cond2, \"score\"] = 8\n",
    "\n",
    "# 淇濆瓨\n",
    "output_file = r\"D:\\Hospital_Pharmacy program\\data\\processed\\hospital\\hospital_registered\\hospital_wgs84_final_with_score.csv\"\n",
    "df.to_csv(output_file, index=False, encoding=\"utf-8-sig\")\n",
    "\n",
    "# 缁熻\n",
    "print(\"鍘熷WGS鍧愭爣鏁伴噺:\", cond1.sum())\n",
    "print(\"宸ュ晢鍧愭爣濉ˉ鏁伴噺:\", cond2.sum())\n",
    "print(\"鏈€缁堝潗鏍囨暟閲?\", df[\"wgs_lon_true\"].notna().sum())\n",
    "print(\"鏂囦欢淇濆瓨:\", output_file)"
