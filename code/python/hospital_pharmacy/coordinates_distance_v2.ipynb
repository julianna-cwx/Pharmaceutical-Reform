    "            time.sleep(delay)\n",
    "        except Exception as e:\n",
    "            print(f\"绗?{attempt + 1} 娆″皾璇曞嚭鐜板紓甯? {str(e)}\")\n",
    "            break\n",
    "    return {}\n",
    "\n",
    "\n",
    "# ------------------------------\n",
    "# 鍒濆鍖栧湴鐞嗙紪鐮佸櫒\n",
    "# ------------------------------\n",
    "geolocator = Nominatim(\n",
    "    user_agent=\"hospital_geo_validation\",\n",
    "    timeout=30\n",
    ")\n",
    "\n",
    "geocode = RateLimiter(geolocator.reverse, min_delay_seconds=1)\n",
    "\n",
    "\n",
    "def get_address_details(lat, lng):\n",
    "    try:\n",
    "        location = geocode(f\"{lat}, {lng}\", exactly_one=True, language='zh')\n",
    "        return location.raw.get('address', {}) if location else {}\n",
    "    except Exception as e:\n",
    "        print(f\"閫嗗湴鐞嗙紪鐮佸け璐? {str(e)}\")\n",
    "        return {}\n",
    "\n",
    "\n",
    "# ------------------------------\n",
    "# 娴嬭瘯 Nominatim 鏈嶅姟\n",
    "# ------------------------------\n",
    "try:\n",
    "    test_url = \"https://nominatim.openstreetmap.org/reverse?lat=39.9&lon=116.4&format=json\"\n",
    "    response = requests.get(test_url, timeout=5)\n",
    "    print(\"Nominatim 鏈嶅姟姝ｅ父\" if response.status_code == 200 else \"鏈嶅姟杩斿洖閿欒\")\n",
    "except Exception as e:\n",
    "    print(f\"鏃犳硶杩炴帴 Nominatim: {str(e)}\")\n",
    "\n",
    "try:\n",
    "    location = geolocator.reverse(\"31.00779569556785,121.40279835486228\", language='zh')\n",
    "    print(\"娴嬭瘯鏌ヨ鎴愬姛:\", location.address)\n",
    "except Exception as e:\n",
    "    print(f\"娴嬭瘯鏌ヨ澶辫触: {str(e)}\")\n",
    "\n",
    "\n",
    "# ------------------------------\n",
    "# 鐪佷唤杈圭晫鏁版嵁锛堢ず渚嬶級\n",
    "# ------------------------------\n",
    "province_bounds = {\n",
    "    \"鍖椾含甯俓": {\"min_lon\": 115.42, \"max_lon\": 117.51, \"min_lat\": 39.44, \"max_lat\": 41.06},\n",
    "    \"澶╂触甯俓": {\"min_lon\": 116.71, \"max_lon\": 118.07, \"min_lat\": 38.56, \"max_lat\": 40.25},\n",
    "    # 鍏朵粬鐪佷唤杈圭晫淇濇寔鍘熸牱\n",
    "}\n",
    "\n",
    "\n",
    "def check_province(lon, lat, target_province):\n",
    "    bounds = province_bounds.get(target_province)\n",
    "    if not bounds or pd.isna(lon) or pd.isna(lat):\n",
    "        return False\n",
    "    return (\n",
    "        bounds['min_lon'] <= lon <= bounds['max_lon']\n",
    "        and bounds['min_lat'] <= lat <= bounds['max_lat']\n",
    "    )\n",
    "\n",
    "\n",
    "# ------------------------------\n",
    "# 鐪佷唤涓€鑷存€ф鏌n",
    "# ------------------------------\n",
    "df_merged['province_check_gd'] = df_merged.apply(\n",
    "    lambda row: check_province(\n",
    "        row['楂樺痉_wgs84缁忓害'],\n",
    "        row['楂樺痉_wgs84绾害'],\n",
    "        row['鐪佷唤']\n",
    "    ),\n",
    "    axis=1\n",
    ")\n",
    "\n",
    "df_merged['province_check_bd'] = df_merged.apply(\n",
    "    lambda row: check_province(\n",
    "        row['鐧惧害_wgs84缁忓害1'],\n",
    "        row['鐧惧害_wgs84绾害1'],\n",
    "        row['鐪佷唤']\n",
    "    ),\n",
    "    axis=1\n",
    ")\n",
    "\n",
    "print(\"鉁?鐪佷唤杈圭晫妫€鏌ュ畬鎴怽")\n"
   ]
  },
