    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import os\n",
    "\n",
    "# ------------------------------\n",
    "# 鏂囦欢璇诲彇鍑芥暟\n",
    "# ------------------------------\n",
    "def robust_read_csv(file_path):\n",
    "    \"\"\"\n",
    "    灏濊瘯澶氱缂栫爜璇诲彇CSV鏂囦欢\n",
    "    \"\"\"\n",
    "    # 甯歌鐨勭紪鐮佸垪琛紙鎸変紭鍏堢骇鎺掑簭锛塡n",
    "    encodings = [\n",
    "        'utf-8-sig',  # 甯OM鐨刄TF-8\n",
    "        'utf-8',      # 鏍囧噯UTF-8\n",
    "        'gbk',        # 绠€浣撲腑鏂嘩indows\n",
    "        'gb2312',     # 绠€浣撲腑鏂嘰n",
    "        'gb18030',    # 涓枃鍥藉鏍囧噯\n",
    "        'latin1',     # ISO-8859-1\n",
    "        'iso-8859-1', # 鍙︿竴绉嶆媺涓佺紪鐮乗n",
    "        'cp1252',     # Windows鎷変竵缂栫爜\n",
    "    ]\n",
    "    \n",
    "    for encoding in encodings:\n",
    "        try:\n",
    "            print(f\"灏濊瘯浣跨敤 {encoding} 缂栫爜璇诲彇...\")\n",
    "            df = pd.read_csv(file_path, encoding=encoding)\n",
    "            print(f\"鉁?浣跨敤 {encoding} 缂栫爜璇诲彇鎴愬姛锛屽叡 {len(df)} 琛岋紝{len(df.columns)} 鍒梊")\n",
    "            return df\n",
    "        except UnicodeDecodeError:\n",
    "            continue\n",
    "        except Exception as e:\n",
    "            print(f\"浣跨敤 {encoding} 缂栫爜鏃跺嚭閿? {str(e)}\")\n",
    "            continue\n",
    "    \n",
    "    # 濡傛灉鎵€鏈夌紪鐮侀兘澶辫触锛屼娇鐢ㄥ甫閿欒澶勭悊鐨勮鍙朶n",
    "    print(\"鎵€鏈夌紪鐮佸皾璇曞け璐ワ紝浣跨敤閿欒蹇界暐妯″紡璇诲彇...\")\n",
    "    return pd.read_csv(file_path, encoding='utf-8', errors='ignore')\n",
    "\n",
    "# ------------------------------\n",
    "# 鏁版嵁鍔犺浇\n",
    "# ------------------------------\n",
    "file_path = r\"D:\\Hospital_Pharmacy program\\data\\processed\\hospital\\coordinates_place_api\\hospital_place_baidu_gaode_wgs84.csv\"\n",
    "\n",
    "if os.path.exists(file_path):\n",
    "    print(f\"鏂囦欢瀛樺湪锛屽ぇ灏? {os.path.getsize(file_path)} 瀛楄妭\")\n",
    "    df_merged = robust_read_csv(file_path)\n",
    "else:\n",
    "    print(\"閿欒锛氭枃浠朵笉瀛樺湪锛乗")\n",
    "    exit()\n",
    "print(f\"鏁版嵁鍔犺浇瀹屾垚锛屽叡 {len(df_merged)} 鏉¤褰昞")\n",
    "print(\"鍒楀悕:\", df_merged.columns.tolist())\n",
    "print(\"\\n鍓嶅嚑琛屾暟鎹?\")\n",
    "print(df_merged.head())\n",
    "\n",
    "# ------------------------------\n",
    "# Haversine 璺濈鍑芥暟\n",
    "# ------------------------------\n",
    "def haversine_distance(lon1, lat1, lon2, lat2):\n",
    "    \"\"\"\n",
    "    璁＄畻涓や釜 WGS84 鍧愭爣鐐逛箣闂寸殑鍦伴潰璺濈锛堢背锛塡n",
    "    \"\"\"\n",
    "    # 浠讳竴鍧愭爣缂哄け 鈫?杩斿洖 NaN\n",
    "    if pd.isna(lon1) or pd.isna(lat1) or pd.isna(lon2) or pd.isna(lat2):\n",
    "        return np.nan\n",
    "\n",
    "    # 杞姬搴n",
    "    lon1, lat1, lon2, lat2 = map(np.radians, [lon1, lat1, lon2, lat2])\n",
    "\n",
    "    dlon = lon2 - lon1\n",
    "    dlat = lat2 - lat1\n",
    "\n",
    "    a = (\n",
    "        np.sin(dlat / 2) ** 2\n",
    "        + np.cos(lat1) * np.cos(lat2) * np.sin(dlon / 2) ** 2\n",
    "    )\n",
    "    c = 2 * np.arcsin(np.sqrt(a))\n",
    "    r = 6371000  # 鍦扮悆骞冲潎鍗婂緞锛堢背锛塡n",
    "\n",
    "    return c * r\n",
    "\n",
    "\n",
    "# ------------------------------\n",
    "# 璺濈璁＄畻锛堢櫨搴?vs 楂樺痉锛塡n",
    "# ------------------------------\n",
    "df_merged[\"distance\"] = df_merged.apply(\n",
    "    lambda row: haversine_distance(\n",
    "        row[\"鐧惧害_wgs84缁忓害1\"], row[\"鐧惧害_wgs84绾害1\"],\n",
    "        row[\"楂樺痉_wgs84缁忓害\"], row[\"楂樺痉_wgs84绾害\"],\n",
    "    ),\n",
    "    axis=1\n",
    ")\n",
    "\n",
    "# ------------------------------\n",
    "# 璺濈缁熻\n",
    "# ------------------------------\n",
    "distance_stats = df_merged[\"distance\"].describe()\n",
    "print(\"鐧惧害 vs 楂樺痉 WGS84 璺濈鍋忓樊缁熻锛歕")\n",
    "print(distance_stats)\n",
    "\n",
    "\n",
    "# ------------------------------\n",
    "# 鍩虹瀛楁绫诲瀷瑙勮寖锛堥槻姝㈠悗缁?groupby / 瀵煎嚭闂锛塡n",
    "# ------------------------------\n",
