    "import pandas as pd\n",
    "import chardet\n",
    "import os\n",
    "import re\n",
    "\n",
    "def detect_file_encoding(file_path, sample_size=10000):\n",
    "    \"\"\"\n",
    "    妫€娴嬫枃浠剁殑缂栫爜鏍煎紡\n",
    "    \"\"\"\n",
    "    with open(file_path, 'rb') as file:\n",
    "        raw_data = file.read(sample_size)\n",
    "        result = chardet.detect(raw_data)\n",
    "        return result['encoding']\n",
    "\n",
    "\n",
    "def process_hospital_data(\n",
    "    \n",
    "    input_file,\n",
    "    output_dir='D:/Hospital_Pharmacy program/data/processed/hospital/hospital_registered'\n",
    "):\n",
    "    \"\"\"\n",
