    "# 閫嗗湴鐞嗙紪鐮侊紙甯﹂噸璇曪級\n",
    "# ------------------------------\n",
    "def get_address_details_with_retry(lat, lng, retries=3, delay=2):\n",
    "    for attempt in range(retries):\n",
    "        try:\n",
    "            location = geocode(f\"{lat}, {lng}\", exactly_one=True, language='zh')\n",
