    "#澧炲姞杩為攣鑽簵鍗犳瘮鍜屾暟閲忕殑鍙樺寲\n",
    "\n",
    "import pandas as pd\n",
    "import geopandas as gpd\n",
    "from tqdm import tqdm\n",
    "import os\n",
    "import chardet\n",
    "\n",
    "# ================================\n",
    "# 鑷姩妫€娴嬬紪鐮乗n",
    "# ================================\n",
    "def get_file_encoding(file_path):\n",
    "    with open(file_path, 'rb') as f:\n",
    "        raw_data = f.read(10000)\n",
    "    result = chardet.detect(raw_data)\n",
    "    return result['encoding']\n",
    "\n",
    "# ================================\n",
    "# 鏍稿績鍑芥暟\n",
    "# ================================\n",
    "def process_year_optimized(year):\n",
    "    try:\n",
    "        # ===================== 鏂囦欢璺緞 =====================\n",
    "        hospital_path = f\"D:/Hospital_Pharmacy program/data/processed/hospital/hospital_registered/hospital_register_final_{year}.csv\"\n",
    "        drugstore_path = f\"D:/Hospital_Pharmacy program/data/processed/pharmacy/real_pharmacy_data/real_pharmacy_dzdp_pharmacies_{year}.csv\"\n",
    "\n",
    "        # ===================== 璇诲彇鍖婚櫌鏁版嵁 =====================\n",
    "        hospital_df = None\n",
    "        try:\n",
    "            enc = get_file_encoding(hospital_path)\n",
    "            hospital_df = pd.read_csv(hospital_path, encoding=enc)\n",
    "            print(f\"{year} 鍖婚櫌鏁版嵁缂栫爜: {enc}\")\n",
    "        except:\n",
    "            for enc in ['utf-8', 'gbk', 'gb2312', 'utf-8-sig', 'gb18030']:\n",
    "                try:\n",
    "                    hospital_df = pd.read_csv(hospital_path, encoding=enc)\n",
    "                    print(f\"{year} 鍖婚櫌鏁版嵁鍏滃簳缂栫爜: {enc}\")\n",
    "                    break\n",
    "                except:\n",
    "                    continue\n",
    "\n",
    "        if hospital_df is None:\n",
    "            print(f\"鏃犳硶璇诲彇鍖婚櫌鏁版嵁: {hospital_path}\")\n",
    "            return None\n",
    "\n",
    "        # ===================== 璇诲彇鑽簵鏁版嵁 =====================\n",
    "        drugstore_df = None\n",
    "        try:\n",
    "            enc = get_file_encoding(drugstore_path)\n",
    "            drugstore_df = pd.read_csv(drugstore_path, encoding=enc)\n",
    "            print(f\"{year} 鑽簵鏁版嵁缂栫爜: {enc}\")\n",
    "        except:\n",
    "            for enc in ['utf-8', 'gbk', 'gb2312', 'utf-8-sig', 'gb18030']:\n",
    "                try:\n",
    "                    drugstore_df = pd.read_csv(drugstore_path, encoding=enc)\n",
    "                    print(f\"{year} 鑽簵鏁版嵁鍏滃簳缂栫爜: {enc}\")\n",
    "                    break\n",
    "                except:\n",
    "                    continue\n",
    "\n",
    "        if drugstore_df is None:\n",
    "            print(f\"鏃犳硶璇诲彇鑽簵鏁版嵁: {drugstore_path}\")\n",
    "            return None\n",
    "\n",
    "        # ===================== GeoDataFrame =====================\n",
    "        hospital_gdf = gpd.GeoDataFrame(\n",
    "            hospital_df,\n",
    "            geometry=gpd.points_from_xy(hospital_df['wgs_lon_true'], hospital_df['wgs_lat_true']),\n",
    "            crs=\"EPSG:4326\"\n",
    "        )\n",
    "\n",
    "        drugstore_gdf = gpd.GeoDataFrame(\n",
    "            drugstore_df,\n",
    "            geometry=gpd.points_from_xy(drugstore_df['lon_wgs'], drugstore_df['lat_wgs']),\n",
    "            crs=\"EPSG:4326\"\n",
    "        )\n",
    "\n",
    "        # 鎶曞奖鍧愭爣锛堢背锛塡n",
    "        hospital_gdf = hospital_gdf.to_crs(\"EPSG:3857\")\n",
    "        drugstore_gdf = drugstore_gdf.to_crs(\"EPSG:3857\")\n",
    "\n",
    "        # ===================== 绌洪棿绱㈠紩 =====================\n",
    "        drugstore_sindex = drugstore_gdf.sindex\n",
    "\n",
    "        # ===================== 鍒濆鍖栧彉閲?=====================\n",
    "        hospital_gdf['pharmacy_count_1km'] = 0\n",
    "        hospital_gdf['pharmacy_count_2km'] = 0\n",
    "        hospital_gdf['pharmacy_count_3km'] = 0\n",
    "\n",
    "        hospital_gdf['chain_pharmacy_count_1km'] = 0\n",
    "        hospital_gdf['chain_pharmacy_count_2km'] = 0\n",
    "        hospital_gdf['chain_pharmacy_count_3km'] = 0\n",
    "\n",
    "        # ===================== 涓诲惊鐜?=====================\n",
    "        for idx, hospital in tqdm(hospital_gdf.iterrows(), total=len(hospital_gdf), desc=f\"{year}\"):\n",
    "\n",
    "            buffer_3km = hospital.geometry.buffer(3000)\n",
    "\n",
    "            possible_idx = list(drugstore_sindex.intersection(buffer_3km.bounds))\n",
    "            possible_matches = drugstore_gdf.iloc[possible_idx]\n",
    "\n",
    "            precise_matches = possible_matches[possible_matches.geometry.within(buffer_3km)]\n",
    "\n",
    "            for _, pharmacy in precise_matches.iterrows():\n",
    "\n",
    "                # 璺濈\n",
    "                distance_km = hospital.geometry.distance(pharmacy.geometry) / 1000\n",
    "\n",
    "                # ===== is_chains 澶勭悊 =====\n",
    "                is_chain = pharmacy.get('is_chains', 0)\n",
    "\n",
    "                if pd.isna(is_chain):\n",
    "                    is_chain = 0\n",
    "\n",
    "                if isinstance(is_chain, str):\n",
    "                    is_chain = 1 if is_chain.lower() in ['1', 'true', 'yes'] else 0\n",
    "\n",
    "                # ===== 鎬绘暟閲?=====\n",
    "                if distance_km <= 1:\n",
    "                    hospital_gdf.at[idx, 'pharmacy_count_1km'] += 1\n",
    "                if distance_km <= 2:\n",
    "                    hospital_gdf.at[idx, 'pharmacy_count_2km'] += 1\n",
    "                if distance_km <= 3:\n",
    "                    hospital_gdf.at[idx, 'pharmacy_count_3km'] += 1\n",
    "\n",
    "                # ===== 杩為攣鏁伴噺 =====\n",
    "                if is_chain == 1:\n",
    "                    if distance_km <= 1:\n",
    "                        hospital_gdf.at[idx, 'chain_pharmacy_count_1km'] += 1\n",
    "                    if distance_km <= 2:\n",
    "                        hospital_gdf.at[idx, 'chain_pharmacy_count_2km'] += 1\n",
    "                    if distance_km <= 3:\n",
    "                        hospital_gdf.at[idx, 'chain_pharmacy_count_3km'] += 1\n",
    "\n",
    "        # ===================== 璁＄畻鍗犳瘮 =====================\n",
    "        hospital_gdf['chain_share_1km'] = hospital_gdf['chain_pharmacy_count_1km'] / hospital_gdf['pharmacy_count_1km'].replace(0, pd.NA)\n",
    "        hospital_gdf['chain_share_2km'] = hospital_gdf['chain_pharmacy_count_2km'] / hospital_gdf['pharmacy_count_2km'].replace(0, pd.NA)\n",
    "        hospital_gdf['chain_share_3km'] = hospital_gdf['chain_pharmacy_count_3km'] / hospital_gdf['pharmacy_count_3km'].replace(0, pd.NA)\n",
    "\n",
    "        # ===================== 淇濆瓨 =====================\n",
    "        hospital_gdf = hospital_gdf.to_crs(\"EPSG:4326\")\n",
    "\n",
    "        output_path = f\"D:/Hospital_Pharmacy program/data/processed/hospital_pharmacy/hospital_with_pharmacy_counts_registered/hospital_with_pharmacy_counts_{year}.csv\"\n",
    "        os.makedirs(os.path.dirname(output_path), exist_ok=True)\n",
    "\n",
    "        hospital_gdf.drop(columns=['geometry']).to_csv(output_path, index=False, encoding='utf-8-sig')\n",
    "\n",
    "        print(f\"瀹屾垚 {year} 骞碶")\n",
    "\n",
    "        return hospital_gdf\n",
    "\n",
    "    except Exception as e:\n",
    "        print(f\"{year} 鍑洪敊: {str(e)}\")\n",
    "        import traceback\n",
    "        traceback.print_exc()\n",
    "        return None\n",
    "\n",
    "\n",
    "# ================================\n",
    "# 涓荤▼搴廫n",
    "# ================================\n",
    "print(\"=\" * 50)\n",
    "print(\"寮€濮嬪鐞?012骞碶")\n",
    "print(\"=\" * 50)\n",
    "\n",
    "result = process_year_optimized(2012)\n",
    "\n",
    "if result is not None:\n",
    "    for year in range(2021, 2022):\n",
    "        print(f\"\\n澶勭悊 {year} 骞碶")\n",
    "        process_year_optimized(year)\n",
    "\n",
    "    print(\"\\n鍏ㄩ儴瀹屾垚锛乗")\n",
    "else:\n",
    "    print(\"2012澶辫触锛屽仠姝")\n"
   ]
