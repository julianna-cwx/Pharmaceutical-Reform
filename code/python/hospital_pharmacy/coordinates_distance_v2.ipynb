   "source": [
    "import os\n",
    "import pickle\n",
    "\n",
    "# 绗叚閮ㄥ垎锛氬亸宸暟鎹垎鏋愬拰閫嗗湴鐞嗙紪鐮乗n",
    "THRESHOLD_MIN = 500\n",
    "THRESHOLD_MAX = 5000\n",
    "\n",
    "# 绛涢€変笉鍚岄槇鍊艰寖鍥寸殑鍋忓樊鏁版嵁\n",
    "large_deviation_500_5000 = df_merged[\n",
    "    (df_merged['distance'] > THRESHOLD_MIN) &\n",
    "    (df_merged['distance'] <= THRESHOLD_MAX)\n",
    "].copy()\n",
    "\n",
    "large_deviation_5000 = df_merged[\n",
    "    df_merged['distance'] > THRESHOLD_MAX\n",
    "].copy()\n",
    "\n",
    "print(f\"涓瓑鍋忓樊璁板綍(500鈥?000绫?: {len(large_deviation_500_5000)}\")\n",
    "print(f\"澶у亸宸褰?>5000绫?: {len(large_deviation_5000)}\")\n",
    "\n",
    "\n",
    "# 閫嗗湴鐞嗙紪鐮佺紦瀛樿矾寰刓n",
    "BASE_DIR = r\"D:\\Hospital_Pharmacy program\\data\\processed\\hospital\\coordinates_place_api\"\n",
    "GEOCODE_CACHE_FILE = os.path.join(BASE_DIR, \"geocode_cache.pkl\")\n",
    "\n",
    "\n",
    "def load_geocode_cache():\n",
    "    if os.path.exists(GEOCODE_CACHE_FILE):\n",
    "        try:\n",
    "            with open(GEOCODE_CACHE_FILE, 'rb') as f:\n",
    "                cache = pickle.load(f)\n",
    "                print(f\"宸插姞杞介€嗗湴鐞嗙紪鐮佺紦瀛橈紝鍖呭惈 {len(cache)} 鏉¤褰昞")\n",
    "                return cache\n",
    "        except Exception as e:\n",
    "            print(f\"鍔犺浇缂撳瓨澶辫触: {e}\")\n",
    "    return {}\n",
    "\n",
    "\n",
    "def save_geocode_cache(cache):\n",
    "    try:\n",
    "        with open(GEOCODE_CACHE_FILE, 'wb') as f:\n",
    "            pickle.dump(cache, f)\n",
    "        print(f\"閫嗗湴鐞嗙紪鐮佺紦瀛樺凡淇濆瓨锛屽寘鍚?{len(cache)} 鏉¤褰昞")\n",
    "    except Exception as e:\n",
    "        print(f\"淇濆瓨缂撳瓨澶辫触: {e}\")\n",
    "\n",
    "\n",
    "def get_address_details_with_cache(lat, lng, cache):\n",
    "    cache_key = f\"{lat:.6f},{lng:.6f}\"\n",
    "\n",
    "    if cache_key in cache:\n",
    "        return cache[cache_key]\n",
    "\n",
    "    address_details = get_address_details(lat, lng)\n",
    "    cache[cache_key] = address_details\n",
    "\n",
    "    if len(cache) % 10 == 0:\n",
    "        save_geocode_cache(cache)\n",
    "\n",
    "    return address_details\n",
    "\n",
    "\n",
    "# 鍔犺浇缂撳瓨\n",
    "geocode_cache = load_geocode_cache()\n",
    "\n",
    "\n",
    "# 涓瓑鍋忓樊璁板綍鐨勯€嗗湴鐞嗙紪鐮乗n",
    "if len(large_deviation_500_5000) > 0:\n",
    "    print(\"寮€濮嬪鐞嗕腑绛夊亸宸褰曠殑閫嗗湴鐞嗙紪鐮?..\")\n",
    "\n",
    "    large_deviation_500_5000['gd_address'] = large_deviation_500_5000.progress_apply(\n",
    "        lambda row: get_address_details_with_cache(\n",
    "            row['楂樺痉_wgs84绾害'],\n",
    "            row['楂樺痉_wgs84缁忓害'],\n",
    "            geocode_cache\n",
    "        ),\n",
    "        axis=1\n",
    "    )\n",
    "\n",
    "    large_deviation_500_5000['bd_address'] = large_deviation_500_5000.progress_apply(\n",
    "        lambda row: get_address_details_with_cache(\n",
    "            row['鐧惧害_wgs84绾害1'],\n",
    "            row['鐧惧害_wgs84缁忓害1'],\n",
    "            geocode_cache\n",
    "        ),\n",
    "        axis=1\n",
    "    )\n",
    "\n",
    "\n",
    "# 澶у亸宸褰曠殑閫嗗湴鐞嗙紪鐮乗n",
    "if len(large_deviation_5000) > 0:\n",
    "    print(\"寮€濮嬪鐞嗗ぇ鍋忓樊璁板綍鐨勯€嗗湴鐞嗙紪鐮?..\")\n",
    "\n",
    "    large_deviation_5000['gd_address'] = large_deviation_5000.progress_apply(\n",
    "        lambda row: get_address_details_with_cache(\n",
    "            row['楂樺痉_wgs84绾害'],\n",
    "            row['楂樺痉_wgs84缁忓害'],\n",
    "            geocode_cache\n",
    "        ),\n",
    "        axis=1\n",
    "    )\n",
    "\n",
    "    large_deviation_5000['bd_address'] = large_deviation_5000.progress_apply(\n",
    "        lambda row: get_address_details_with_cache(\n",
    "            row['鐧惧害_wgs84绾害1'],\n",
    "            row['鐧惧害_wgs84缁忓害1'],\n",
    "            geocode_cache\n",
    "        ),\n",
    "        axis=1\n",
    "    )\n",
    "\n",
    "\n",
    "# 淇濆瓨缂撳瓨\n",
    "save_geocode_cache(geocode_cache)\n",
    "\n",
    "\n",
    "large_deviation_500_5000.to_csv(\n",
    "    os.path.join(BASE_DIR, \"large_deviation_500_5000.csv\"),\n",
    "    index=False,\n",
    "    encoding=\"utf-8-sig\"\n",
    ")\n",
    "\n",
    "large_deviation_5000.to_csv(\n",
    "    os.path.join(BASE_DIR, \"large_deviation_5000.csv\"),\n",
    "    index=False,\n",
    "    encoding=\"utf-8-sig\"\n",
    ")\n",
    "\n",
    "print(\"閫嗗湴鐞嗙紪鐮佸畬鎴怽")\n"
   ]
  },
